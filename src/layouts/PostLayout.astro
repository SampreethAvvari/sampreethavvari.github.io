---
import { Image } from "astro:assets";

import BaseLayout from "./BaseLayout.astro";

import { info } from "../data/info";
import Contact from "../components/contact_section/Contact";

const { frontmatter } = Astro.props;

const {
  title,
  date,
  description,
  img_path,
  img_alt,
  tag,
  tone,
  stats,
} = frontmatter;

const TAG_TONE: Record<string, string> = {
  MLOps: "emerald",
  Architecture: "blue",
  Engineering: "blue",
  Process: "amber",
  Research: "violet",
  Personal: "cyan",
  Filmmaking: "amber",
};

const chipTone = tone || (tag ? TAG_TONE[tag] : null) || "blue";
---

<BaseLayout title={title}>
  <div class="post-progress" id="post-progress"></div>

  <article class="post-article">
    <header class="post-hero">
      <div class="post-hero-atmos"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 lg:px-0">
        <a href="/posts" class="post-backlink">← All posts</a>

        <div class="post-meta">
          {date && <span class="post-date">{date}</span>}
          {
            tag && (
              <span class={`post-tag post-tag-${chipTone}`}>{tag}</span>
            )
          }
        </div>

        <h1 class="post-title">{title}</h1>

        {description && <p class="post-lede">{description}</p>}
      </div>
    </header>

    {
      img_path && (
        <div class="mx-auto max-w-5xl px-6 lg:px-0">
          <Image
            src={img_path}
            alt={img_alt || title}
            class="post-cover"
            width={1200}
            height={600}
          />
        </div>
      )
    }

    {
      Array.isArray(stats) && stats.length > 0 && (
        <div class="mx-auto max-w-4xl px-6 lg:px-0 mt-10">
          <div class="post-stats-grid">
            {stats.map((s: { value: string; label: string; tone?: string }) => (
              <div class={`stat-callout stat-${s.tone || "blue"}`}>
                <div class="stat-value">{s.value}</div>
                <div class="stat-label">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <div class="mx-auto max-w-3xl px-6 lg:px-0 mt-16">
      <div class="prose prose-lg dark:prose-invert max-w-none post-prose">
        <slot />
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-6 lg:px-0 mt-20 mb-24">
      <div class="post-author">
        <Image
          src={info.picture}
          alt={info.picture_alt}
          class="post-author-pic"
          width={64}
          height={64}
        />
        <div class="flex-1">
          <p class="post-author-name">{info.name}</p>
          <p class="post-author-role">{info.role}, {info.location}</p>
          <p class="post-author-bio">{info.brief_description}</p>
          <Contact contact={info.contact} size="md" client:visible />
        </div>
      </div>
    </div>
  </article>

  <script is:inline>
    (function () {
      const bar = document.getElementById("post-progress");
      if (!bar) return;
      const update = () => {
        const doc = document.documentElement;
        const scrollTop = doc.scrollTop || document.body.scrollTop;
        const height = doc.scrollHeight - doc.clientHeight;
        const pct = height > 0 ? (scrollTop / height) * 100 : 0;
        bar.style.width = pct + "%";
      };
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
      update();
    })();
  </script>
</BaseLayout>
