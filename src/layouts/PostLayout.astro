---
import Picture from "../components/common/Picture.astro";

import BaseLayout from "./BaseLayout.astro";

import { info } from "../data/info";
import Contact from "../components/contact_section/Contact";
// Article styles live in their own sheet so only post pages download them.
import "../styles/post-article.css";

const { frontmatter } = Astro.props;

const {
  title,
  date,
  description,
  img_path,
  img_alt,
  tag,
  tone,
  stats,
} = frontmatter;

const TAG_TONE: Record<string, string> = {
  MLOps: "emerald",
  Architecture: "blue",
  Engineering: "blue",
  Process: "amber",
  Research: "violet",
  Personal: "cyan",
  Filmmaking: "amber",
};

const chipTone = tone || (tag ? TAG_TONE[tag] : null) || "blue";
// Preload the cover (the LCP element on a post page) as AVIF.
const coverPreload = img_path?.replace(/\.(png|jpe?g)$/i, ".avif");
---

<BaseLayout title={title} preloadImage={coverPreload}>
  <div class="post-progress" id="post-progress"></div>

  <article class="post-article">
    <header class="post-hero">
      <div class="post-hero-atmos"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 lg:px-0">
        <a href="/posts" class="post-backlink">← All posts</a>

        <div class="post-meta">
          {date && <span class="post-date">{date}</span>}
          {
            tag && (
              <span class={`post-tag post-tag-${chipTone}`}>{tag}</span>
            )
          }
        </div>

        <h1 class="post-title">{title}</h1>

        {description && <p class="post-lede">{description}</p>}
      </div>
    </header>

    {
      img_path && (
        <div class="mx-auto max-w-5xl px-6 lg:px-0">
          <Picture
            src={img_path}
            alt={img_alt || title}
            class="post-cover"
            width={1200}
            height={600}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )
    }

    {
      Array.isArray(stats) && stats.length > 0 && (
        <div class="mx-auto max-w-4xl px-6 lg:px-0 mt-10">
          <div class="post-stats-grid">
            {stats.map((s: { value: string; label: string; tone?: string }) => (
              <div class={`stat-callout stat-${s.tone || "blue"}`}>
                <div class="stat-value">{s.value}</div>
                <div class="stat-label">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <div class="mx-auto max-w-7xl px-6 lg:px-10 xl:px-14 mt-16 post-body-grid">
      <aside class="post-toc-wrap" aria-hidden="true">
        <nav class="post-toc" id="post-toc">
          <p class="post-toc-label">In this post</p>
          <ol id="post-toc-list"></ol>
        </nav>
      </aside>
      <div class="post-body">
        <div class="prose prose-lg dark:prose-invert max-w-none post-prose" id="post-prose-body">
          <slot />
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-6 lg:px-0 mt-20 mb-24">
      <div class="post-author">
        <Picture
          src={info.picture}
          alt={info.picture_alt}
          class="post-author-pic"
          width={64}
          height={64}
        />
        <div class="flex-1">
          <p class="post-author-name">{info.name}</p>
          <p class="post-author-role">{info.role}, {info.location}</p>
          <p class="post-author-bio">{info.brief_description}</p>
          <Contact contact={info.contact} size="md" client:visible />
        </div>
      </div>
    </div>
  </article>

  <script is:inline>
    (function () {
      const bar = document.getElementById("post-progress");
      if (bar) {
        const updateBar = () => {
          const doc = document.documentElement;
          const scrollTop = doc.scrollTop || document.body.scrollTop;
          const height = doc.scrollHeight - doc.clientHeight;
          const pct = height > 0 ? (scrollTop / height) * 100 : 0;
          bar.style.width = pct + "%";
        };
        window.addEventListener("scroll", updateBar, { passive: true });
        window.addEventListener("resize", updateBar);
        updateBar();
      }

      // Build the side TOC from h2 elements inside the prose body.
      const body = document.getElementById("post-prose-body");
      const list = document.getElementById("post-toc-list");
      const tocWrap = document.querySelector(".post-toc-wrap");
      if (body && list && tocWrap) {
        const slugify = (s) =>
          s.toLowerCase().trim()
            .replace(/[^a-z0-9\s-]/g, "")
            .replace(/\s+/g, "-")
            .replace(/-+/g, "-")
            .slice(0, 80);

        const headings = Array.from(body.querySelectorAll("h2"));
        if (headings.length < 2) {
          // Not worth a TOC for one section.
          tocWrap.style.display = "none";
        } else {
          tocWrap.removeAttribute("aria-hidden");
          headings.forEach((h, i) => {
            if (!h.id) h.id = "section-" + (slugify(h.textContent || "") || i);
            const li = document.createElement("li");
            const a = document.createElement("a");
            a.href = "#" + h.id;
            a.textContent = h.textContent || "";
            a.dataset.target = h.id;
            li.appendChild(a);
            list.appendChild(li);
          });

          // Scroll-spy the active section.
          const linksById = {};
          list.querySelectorAll("a").forEach((a) => {
            linksById[a.dataset.target] = a.parentElement;
          });
          const obs = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                const li = linksById[entry.target.id];
                if (!li) return;
                if (entry.isIntersecting) {
                  Object.values(linksById).forEach((l) => l.classList.remove("toc-active"));
                  li.classList.add("toc-active");
                }
              });
            },
            { rootMargin: "-15% 0px -70% 0px", threshold: 0 },
          );
          headings.forEach((h) => obs.observe(h));
        }
      }
    })();
  </script>
</BaseLayout>
