---
import Nav from "../components/navbar/Nav";
import TopButton from "../components/TopButton";
import Pointer from "../components/Pointer";
import ChatWidget from "../components/chatbot/ChatWidget";
import FooterBar from "../components/footer/FooterBar";
import { info } from "../data/info";

const {
  title,
  description = "AI Engineer specializing in agentic AI, RAG, and ML systems.",
  footerVariant = "default",
} = Astro.props;

// Canonical URL for the current page (no query strings), absolute via astro.config `site`.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
// Absolute URL for social-share / structured-data image.
const ogImage = new URL(info.picture, Astro.site).toString();

// Person structured data. The `sameAs` array tells Google the portfolio,
// LinkedIn, and GitHub all belong to the same Sampreeth Avvari.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: info.name,
  jobTitle: info.role,
  url: Astro.site?.toString(),
  image: ogImage,
  email: info.contact.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: "New York",
    addressRegion: "NY",
    addressCountry: "US",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "New York University",
  },
  // Canonical profile URLs (NOT the Switchy short links in info.contact) so the
  // structured data establishes identity correctly for search engines.
  sameAs: [
    "https://www.linkedin.com/in/sampreethavvari/",
    "https://github.com/SampreethAvvari",
    "https://www.instagram.com/sampreeth.sharma/",
  ],
};
const posts = await Astro.glob("../pages/posts/*.md");
const pages = [
  {
    title: "Home",
    description: "Landing, hero, and quick intro.",
    url: "/",
  },
  {
    title: "About",
    description: "Bio, education, skills, and experience.",
    url: "/#about",
  },
  {
    title: "Work",
    description: "Four disciplines: AI, forward-deployed, ML, and software engineering.",
    url: "/work",
  },
  {
    title: "Gallery",
    description: "Screenshots and documents from production systems, by project.",
    url: "/gallery",
  },
  {
    title: "Projects",
    description: "AI, research, and industry projects.",
    url: "/projects",
  },
  {
    title: "Filmmaking",
    description: "Among Monsters and film work.",
    url: "/filmmaking",
  },
  {
    title: "Writing",
    description: "Blog posts and research notes.",
    url: "/posts",
  },
  {
    title: "Contact",
    description: "Email and social links.",
    url: "/#contact",
  },
];

const searchItems = [
  ...pages.map((page) => ({ ...page, type: "page" })),
  ...posts.map((post) => ({
    title: post.frontmatter.title,
    description: post.frontmatter.description,
    url: post.url,
    type: "post",
  })),
];

import "../styles/global.css";
---

<!doctype html>
<html lang="en" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="keywords" content="Sampreeth Avvari, AI engineer, agentic AI, RAG, ML, MLOps, NYU" />
    <meta name="author" content="Sampreeth Avvari" />
    <meta http-equiv="Content-Language" content="en" />
    <meta name="google" content="notranslate" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="/logos/samp-chat.png" />
    <link rel="apple-touch-icon" href="/logos/samp-chat.png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Sampreeth Avvari RSS"
      href={`${Astro.site}rss.xml`}
    />
    <meta name="generator" content={Astro.generator} />
    <!-- Open Graph / social share -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sampreeth Avvari" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Person structured data: links portfolio + LinkedIn + GitHub as one identity -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="text/javascript">
      (function () {
        var css = document.createElement("link");
        css.href =
          "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css";
        css.rel = "stylesheet";
        css.integrity =
          "sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==";
        css.crossOrigin = "anonymous";
        css.referrerPolicy = "no-referrer";
        document.head.appendChild(css);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/normalize.css@8.0.1/normalize.min.css"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Cloudflare Web Analytics — privacy-first, cookieless, no consent
      // banner needed. Just basic traffic stats. Replaces GA4.
      // Get the token: dash.cloudflare.com → Web Analytics → Add a site
      // (manual) → copy the value of "token" and paste it below.
      (function () {
        var CF_BEACON_TOKEN = "643bcd2b05614ef2b29da4c4f0409d04";
        var host = location.hostname;
        if (host === "localhost" || host === "127.0.0.1") return; // dev runs don't count
        if (!CF_BEACON_TOKEN || CF_BEACON_TOKEN.indexOf("__") === 0) return; // token not set yet
        var s = document.createElement("script");
        s.defer = true;
        s.src = "https://static.cloudflareinsights.com/beacon.min.js";
        s.setAttribute("data-cf-beacon", JSON.stringify({ token: CF_BEACON_TOKEN }));
        document.head.appendChild(s);
      })();
    </script>
    <script>
      // On page load or when changing themes, best to add inline in `head` to avoid FOUC
      if (
        localStorage.getItem("theme") === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
    <script>
      const setupReveal = () => {
        const elements = document.querySelectorAll("[data-reveal]");
        if (!elements.length) return;

        if (!("IntersectionObserver" in window)) {
          elements.forEach((el) => el.classList.add("reveal-visible"));
          return;
        }

        if (!window.__revealObserver) {
          window.__revealObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("reveal-visible");
                } else {
                  entry.target.classList.remove("reveal-visible");
                }
              });
            },
            { threshold: 0.2 }
          );
        }

        elements.forEach((el) => {
          if (el.dataset.revealObserved) return;
          el.dataset.revealObserved = "true";
          window.__revealObserver.observe(el);
        });
      };

      const boot = () => {
        setupReveal();
        if ("MutationObserver" in window) {
          const observer = new MutationObserver(() => setupReveal());
          observer.observe(document.body, { childList: true, subtree: true });
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot);
      } else {
        boot();
      }
    </script>
  </head>
  <body class="bg-primary dark:bg-dk-primary text-text dark:text-dk-text w-full overflow-x-hidden font-display">
    <Nav client:visible searchItems={searchItems} />
    <main class="w-full">
      <slot />
    </main>
    <FooterBar variant={footerVariant} />
    <ChatWidget client:only />
    <TopButton client:only />
    <Pointer client:only />
  </body>
</html>
