---
import Nav from "../components/navbar/Nav";
import TopButton from "../components/TopButton";
import Pointer from "../components/Pointer";
import ChatWidget from "../components/chatbot/ChatWidget";
import FooterBar from "../components/footer/FooterBar";
import SpaceField from "../components/hero/SpaceField.astro";
import { info } from "../data/info";
import "../styles/landing.css";

const {
  title,
  description = "AI Engineer specializing in agentic AI, RAG, and ML systems.",
  footerVariant = "default",
  // Optional LCP image to preload (an AVIF path). Pages pass their above-the-fold
  // hero/cover so the browser fetches it before it discovers the <img> in markup.
  preloadImage,
} = Astro.props;

// Canonical URL for the current page (no query strings), absolute via astro.config `site`.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
// Absolute URL for social-share / structured-data image.
const ogImage = new URL(info.picture, Astro.site).toString();

// Person structured data. The `sameAs` array tells Google the portfolio,
// LinkedIn, and GitHub all belong to the same Sampreeth Avvari.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: info.name,
  jobTitle: info.role,
  url: Astro.site?.toString(),
  image: ogImage,
  email: info.contact.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: "New York",
    addressRegion: "NY",
    addressCountry: "US",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "New York University",
  },
  // Canonical profile URLs (NOT the Switchy short links in info.contact) so the
  // structured data establishes identity correctly for search engines.
  sameAs: [
    "https://www.linkedin.com/in/sampreethavvari/",
    "https://github.com/SampreethAvvari",
    "https://www.instagram.com/sampreeth.sharma/",
  ],
};
import { searchItems } from "../data/searchItems";

import "../styles/global.css";
---

<!doctype html>
<html lang="en" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="keywords" content="Sampreeth Avvari, AI engineer, agentic AI, RAG, ML, MLOps, NYU" />
    <meta name="author" content="Sampreeth Avvari" />
    <meta http-equiv="Content-Language" content="en" />
    <meta name="google" content="notranslate" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {
      preloadImage && (
        <link
          rel="preload"
          as="image"
          href={preloadImage}
          type="image/avif"
          fetchpriority="high"
        />
      )
    }
    <link rel="icon" type="image/png" href="/logos/samp-chat.png" />
    <link rel="apple-touch-icon" href="/logos/samp-chat.png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Sampreeth Avvari RSS"
      href={`${Astro.site}rss.xml`}
    />
    <meta name="generator" content={Astro.generator} />
    <!-- Open Graph / social share -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sampreeth Avvari" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Person structured data: links portfolio + LinkedIn + GitHub as one identity -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <!-- FontAwesome loads non-blocking: media=print swap keeps it off the
         critical path. Critical surfaces use inline SVGs via Icon.astro. -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
      media="print"
      onload="this.media='all'"
    />
    <title>{title}</title>
    <script is:inline>
      // Cloudflare Web Analytics: privacy-first, cookieless, no consent
      // banner needed. Just basic traffic stats. Replaces GA4.
      // Get the token: dash.cloudflare.com → Web Analytics → Add a site
      // (manual) → copy the value of "token" and paste it below.
      (function () {
        var CF_BEACON_TOKEN = "643bcd2b05614ef2b29da4c4f0409d04";
        var host = location.hostname;
        if (host === "localhost" || host === "127.0.0.1") return; // dev runs don't count
        if (!CF_BEACON_TOKEN || CF_BEACON_TOKEN.indexOf("__") === 0) return; // token not set yet
        var s = document.createElement("script");
        s.defer = true;
        s.src = "https://static.cloudflareinsights.com/beacon.min.js";
        s.setAttribute("data-cf-beacon", JSON.stringify({ token: CF_BEACON_TOKEN }));
        document.head.appendChild(s);
      })();
    </script>
    <script is:inline>
      // The site is dark only. Set the class inline in head to avoid FOUC.
      document.documentElement.classList.add("dark");
    </script>
    <script>
      const setupReveal = () => {
        const elements = document.querySelectorAll("[data-reveal]");
        if (!elements.length) return;

        if (!("IntersectionObserver" in window)) {
          elements.forEach((el) => el.classList.add("reveal-visible"));
          return;
        }

        if (!window.__revealObserver) {
          window.__revealObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("reveal-visible");
                } else {
                  entry.target.classList.remove("reveal-visible");
                }
              });
            },
            // threshold 0 (not 0.2) so sections taller than ~5x the viewport
            // still reveal, at 0.2 a very tall section (e.g. AIE's 6 project
            // cards on mobile) could never reach 20% visibility and stayed hidden.
            { threshold: 0, rootMargin: "0px 0px -10% 0px" }
          );
        }

        elements.forEach((el) => {
          if (el.dataset.revealObserved) return;
          el.dataset.revealObserved = "true";
          window.__revealObserver.observe(el);
        });
      };

      const boot = () => {
        setupReveal();
        if ("MutationObserver" in window) {
          // Coalesce mutation bursts (island hydration, chat messages) into
          // one rescan instead of one per DOM change.
          let pending = false;
          const observer = new MutationObserver(() => {
            if (pending) return;
            pending = true;
            setTimeout(() => {
              pending = false;
              setupReveal();
            }, 120);
          });
          observer.observe(document.body, { childList: true, subtree: true });
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot);
      } else {
        boot();
      }
    </script>
  </head>
  <body class="bg-primary dark:bg-dk-primary text-text dark:text-dk-text w-full overflow-x-hidden font-display">
    <!-- Shared space backdrop on every page: starfield, ambient colour
         flow, and film grain. All behind the content (z -1, grain overlay). -->
    <SpaceField />
    <div class="ambient" data-ambient aria-hidden="true"></div>
    <div class="grain" aria-hidden="true"></div>
    <script>
      // Default ambient colour flow; pages with their own section stops
      // (landing, writing) call initAmbient again and win.
      import { initAmbient } from "../scripts/spatial";
      initAmbient([
        ["91,141,239", "52,211,153"],
        ["167,139,250", "34,211,238"],
      ]);
    </script>
    <Nav client:visible searchItems={searchItems} />
    <main class="w-full">
      <slot />
    </main>
    <FooterBar variant={footerVariant} />
    <ChatWidget client:only />
    <TopButton client:only />
    <Pointer client:only />
  </body>
</html>
