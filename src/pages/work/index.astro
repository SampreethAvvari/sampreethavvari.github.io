---
// /work — the overview page. Four full-width alternating discipline panels,
// each previewing its top projects and linking into the deep-dive page.
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkTabs from "../../components/work_section/WorkTabs.astro";
import { disciplines } from "../../data/disciplines";
import Picture from "../../components/common/Picture.astro";

const statusTone = (s: string) =>
  s === "In production" || s === "Live" || s === "Running program"
    ? "dx-chip-live"
    : s === "Pilot-ready" || s === "In build"
      ? "dx-chip-soon"
      : "dx-chip-design";
---

<BaseLayout title="Work · Sampreeth Avvari">
  <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 pt-24 lg:pt-32 pb-20">
    <!-- Hero -->
    <header class="max-w-3xl reveal" data-reveal>
      <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">Work</p>
      <h1 class="display text-text dark:text-dk-text mb-5 glow-wave">
        Four disciplines, <span class="text-secondary dark:text-dk-secondary">one operating mode</span>.
      </h1>
      <p class="text-lg lg:text-xl text-text/70 dark:text-dk-text/70 leading-relaxed">
        Most of this work comes from Hybridge, a dental implant company where
        I've been the only engineer in the building. Every project there runs
        the full arc: find the real problem, design the system, train the model
        or wire the LLM, ship it into someone's workflow, and teach people to
        run it. Different projects lean on different disciplines. Here's the
        work, told four ways.
      </p>
      <div class="mt-7">
        <a
          href="/gallery"
          class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 border border-text/20 dark:border-dk-text/20 text-sm font-semibold text-text dark:text-dk-text hover:bg-text/5 dark:hover:bg-dk-text/10 transition"
        >
          <i class="fas fa-images text-xs" aria-hidden="true"></i>
          Screenshots
        </a>
      </div>
    </header>

    <div class="mt-10">
      <WorkTabs active="all" />
    </div>

    <!-- Discipline panels -->
    <div class="mt-6 flex flex-col gap-12 lg:gap-16">
      {disciplines.map((d, i) => (
        <section
          class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start reveal"
          data-reveal
          style={`--dx: ${d.accent}; --dx-rgb: ${d.rgb};`}
        >
          <div class={`lg:col-span-5 ${i % 2 === 1 ? "lg:order-2" : ""}`}>
            <div class="work-hero-img">
              <Picture
                src={d.heroImg}
                alt={`${d.name} abstract artwork`}
                width={960}
                height={540}
                class="w-full aspect-video object-cover"
              />
            </div>
            <div class="mt-5 flex items-center gap-3">
              <span class="dx-acronym" style={`--dx: ${d.accent}; --dx-rgb: ${d.rgb};`}>{d.acronym}</span>
              <span class="text-xs text-text/45 dark:text-dk-text/45">
                {d.projects.length} projects · {d.articles.length} articles
              </span>
            </div>
          </div>

          <div class={`lg:col-span-7 ${i % 2 === 1 ? "lg:order-1" : ""}`}>
            <h2 class="display-sm text-text dark:text-dk-text mb-4">
              <span style={`color: ${d.accent};`}>{d.name}</span>
            </h2>
            <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed mb-7 max-w-2xl">
              {d.summary}
            </p>

            <ul class="space-y-2.5 mb-7">
              {d.projects.slice(0, 3).map((p) => (
                <li>
                  <a
                    href={p.href ?? `/work/${d.slug}`}
                    class="no-lift group flex items-center gap-4 rounded-xl px-3.5 py-2.5 border border-text/10 dark:border-dk-text/10 hover:border-[rgba(var(--dx-rgb),0.45)] transition"
                  >
                    {p.img && (
                      <Picture src={p.img} alt="" width={120} height={80} class="w-14 h-9 object-cover rounded-md shrink-0" />
                    )}
                    <span class="flex-1 min-w-0">
                      <span class="block text-sm font-semibold text-text dark:text-dk-text truncate group-hover:text-[var(--dx)] transition">
                        {p.name}
                      </span>
                      <span class="block text-xs text-text/55 dark:text-dk-text/55 truncate">
                        {p.oneLiner}
                      </span>
                    </span>
                    <span class={`dx-chip ${statusTone(p.status)} shrink-0 hidden sm:inline-block`}>{p.status}</span>
                  </a>
                </li>
              ))}
            </ul>

            <a
              href={`/work/${d.slug}`}
              class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold transition border"
              style={`color: ${d.accent}; border-color: rgba(${d.rgb}, 0.4); background: rgba(${d.rgb}, 0.08);`}
            >
              Go deep on {d.acronym} <span aria-hidden="true">→</span>
            </a>
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
