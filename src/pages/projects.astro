---
import BaseLayout from "../layouts/BaseLayout.astro";
import { info } from "../data/info";
import { Image } from "astro:assets";

const title = "SA: Projects";

const projects = info.projects;

const slug = (t: string) =>
  t
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "")
    .slice(0, 60);

const cleanTitle = (t: string) =>
  t
    .replace(/\s*\(Hybridge Implants LLC\)\s*$/i, "")
    .replace(/\s*[—-]\s*Hybridge Implants LLC\s*$/i, "")
    .replace(/\s*[—-]\s*Hybridge[^—-]*$/i, "")
    .replace(/\s*-\s*Research\s*$/i, "")
    .trim();

const industry = projects.filter((p: any) => p.tier === "industry");
const research = projects.filter((p: any) => p.tier === "research");
const academic = projects.filter((p: any) => p.tier === "academic");

// Industry chips stay neutral slate so the page reads as black + matte gray;
// the colour comes only from the atmos glow behind each deep dive.
const INDUSTRY_CHIP_TONES = ["slate", "slate", "slate", "slate", "slate", "slate", "slate"];

// Each project's atmos glow takes the ambient colour of its hero image —
// keeps the screen black/matte gray, lets the floating glow do the colour
// signaling. Mapped per filename so adding a new project is one line.
const ATMOS_BY_IMG: Record<string, string> = {
  "/cbct-validator.png": "cyan",
  "/treatment-estimator.png": "violet",
  "/cowork-dashboard.png": "cyan",
  "/loan-radar.png": "blue",
  "/llm-persuasion.png": "violet",
  "/doc-coach.png": "emerald",
  "/npc-coach.png": "emerald",
  "/accounting-automation.png": "amber",
  "/enterprise-data.png": "amber",
};
const atmosToneFor = (p: any) => ATMOS_BY_IMG[p.img_path] || "slate";

// Map project title fragments to their long-form blog post URL. Used for
// inline "Read the write-up" links per deep dive and the closing band.
const POST_FOR: Record<string, string> = {
  "CBCT Scan Validator": "/posts/cbct-scan-validator",
  "Treatment Estimator": "/posts/treatment-estimator",
  "Cowork Dashboard": "/posts/cowork-dashboard",
  "Doc Coach": "/posts/clinical-rag",
  "Consultation QA": "/posts/clinical-rag",
  "Loan Radar": "/posts/loan-radar-mlops",
  "LLM Persuasion": "/posts/llama-rlhf",
};
const postFor = (title: string) => {
  for (const k of Object.keys(POST_FOR)) {
    if (title.includes(k)) return POST_FOR[k];
  }
  return null;
};
const projectsWithBlog = projects
  .map((p: any) => ({ p, post: postFor(p.title) }))
  .filter((x: any) => x.post);
---

<BaseLayout title={title}>
  <script is:inline>
    document.documentElement.classList.add("snap-home");
  </script>

  <!-- ── Hero: Selected work ────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden projects-hero-atmos snap-chapter"
    style="min-height: 92vh; min-height: 92svh; display: flex; flex-direction: column; justify-content: center; padding: 6rem 0 4rem;"
    id="projects-top"
  >
    <div class="relative z-10 mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
      <div class="max-w-4xl">
        <p class="eyebrow text-secondary dark:text-dk-secondary mb-5">
          Selected work
        </p>
        <h1 class="display text-text dark:text-dk-text mb-8 glow-wave">
          Projects.
        </h1>
        <p class="text-lg lg:text-2xl text-text/75 dark:text-dk-text/75 leading-relaxed max-w-3xl">
          Production systems I shipped solo at Hybridge, plus the research and
          coursework that taught me the patterns. Each Hybridge one gets its own
          page; the rest live below.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-6 text-sm text-text/55 dark:text-dk-text/55">
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-acc-blue"></span>
            {industry.length} industry
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-acc-violet"></span>
            {academic.length} academic
          </span>
        </div>
      </div>
    </div>

    <a
      href={`#${slug(industry[0]?.title || "")}`}
      aria-label="Scroll to first project"
      class="no-lift absolute bottom-8 left-1/2 -translate-x-1/2 text-text/40 dark:text-dk-text/40 hover:text-text dark:hover:text-dk-text transition animate-pulse"
    >
      <i class="fas fa-chevron-down text-xl"></i>
    </a>
  </section>

  <!-- ── Band A: Industry deep dives (one screen per project) ───────── -->
  {industry.map((project: any, i: number) => {
    const flip = i % 2 === 1;
    const display = cleanTitle(project.title);
    const shortDesc = project.details?.summary_short || project.description;
    const stats = project.details?.stats || [];
    const star = project.details?.star;
    const tech = project.tech?.slice(0, 8) || [];
    const chipTone = INDUSTRY_CHIP_TONES[i % INDUSTRY_CHIP_TONES.length];
    const blog = postFor(project.title);
    return (
      <section
        class="project-screen snap-chapter relative overflow-hidden"
        id={slug(project.title)}
      >
        <div class={`project-screen-atmos atmos-${atmosToneFor(project)}`} aria-hidden="true"></div>
        <div class="relative z-10 mx-auto w-full max-w-screen-2xl px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class={`lg:col-span-7 ${flip ? "lg:order-2" : ""}`}>
            <div class="relative project-screen-imagewrap">
              <button
                type="button"
                class="flip-card group"
                aria-label={`Show case study for ${display}`}
                data-flip-card
              >
                <div class="flip-card-inner">
                  <div class="flip-card-front">
                    <Image
                      src={project.img_path}
                      alt={project.img_alt || project.title}
                      width={1400}
                      height={875}
                      class="w-full aspect-[16/10] object-cover rounded-2xl shadow-2xl ring-1 ring-text/10 dark:ring-dk-text/15"
                    />
                    <div class="flip-card-hint">
                      <span class="flip-card-hint-icon" aria-hidden="true">↻</span>
                      <span>Click for the case study</span>
                    </div>
                  </div>
                  <div class="flip-card-back">
                    {star ? (
                      <div class="flip-card-back-grid">
                        <div>
                          <p class="flip-section-label">Problem</p>
                          <p class="flip-section-body">{star.problem}</p>
                        </div>
                        <div>
                          <p class="flip-section-label">Solution</p>
                          <p class="flip-section-body">{star.solution}</p>
                        </div>
                        <div>
                          <p class="flip-section-label">Process</p>
                          <p class="flip-section-body">{star.process}</p>
                        </div>
                        <div>
                          <p class="flip-section-label">Result</p>
                          <p class="flip-section-body">{star.result}</p>
                        </div>
                      </div>
                    ) : (
                      <p class="flip-section-body">
                        {project.details?.summary || project.description}
                      </p>
                    )}
                    <div class="flip-card-hint flip-card-hint-back">
                      <span class="flip-card-hint-icon" aria-hidden="true">↺</span>
                      <span>Click to flip back</span>
                    </div>
                  </div>
                </div>
              </button>
            </div>
          </div>
          <div class="lg:col-span-5">
            <div class="flex items-center gap-3 mb-4">
              <span class={`post-tag post-tag-${chipTone}`}>
                Industry · {String(i + 1).padStart(2, "0")}/{String(industry.length).padStart(2, "0")}
              </span>
              <span class="text-xs uppercase tracking-[0.18em] text-text/45 dark:text-dk-text/45 font-semibold">
                {project.date}
              </span>
            </div>
            <h2 class="display-sm text-text dark:text-dk-text mb-5 glow-wave">
              {display}
            </h2>
            <p class="text-base lg:text-lg text-text/75 dark:text-dk-text/80 leading-relaxed mb-7">
              {shortDesc}
            </p>
            {stats.length > 0 && (
              <div class={`stat-grid stat-grid-${atmosToneFor(project)} mb-7`}>
                {stats.map((s: any) => (
                  <div class="stat-cell">
                    <p class="stat-value">{s.value}</p>
                    <p class="stat-label">{s.label}</p>
                  </div>
                ))}
              </div>
            )}
            {tech.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-6">
                {tech.map((t: string) => (
                  <span class="skill-pill text-xs">{t}</span>
                ))}
              </div>
            )}
            <div class="flex flex-wrap items-center gap-4">
              {blog && (
                <a
                  href={blog}
                  class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary inline-flex"
                >
                  Read the write-up <span aria-hidden="true">→</span>
                </a>
              )}
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noreferrer"
                  class="link-underline text-sm font-semibold text-text/60 dark:text-dk-text/60 inline-flex"
                >
                  Visit project <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- ── Band B: Research ───────────────────────────────────────────── -->
  {research.length > 0 && (
    <section class="snap-chapter relative py-24 lg:py-32">
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="max-w-3xl mb-12 lg:mb-16">
          <p class="eyebrow text-acc-violet mb-4">Research</p>
          <h2 class="display-sm text-text dark:text-dk-text glow-wave mb-4">
            Working with researchers.
          </h2>
          <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed">
            Collaborations at NYU on persuasion, alignment, and the
            edges of RLHF.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {research.map((p: any) => (
            <article class="rounded-xl border border-text/10 dark:border-dk-text/15 bg-primary dark:bg-dk-primary/40 overflow-hidden flex flex-col hover:border-text/30 dark:hover:border-dk-text/25 transition">
              <div class="relative overflow-hidden">
                <Image
                  src={p.img_path}
                  alt={p.img_alt || p.title}
                  width={900}
                  height={500}
                  class="w-full aspect-[16/9] object-cover transition duration-500 hover:scale-[1.03]"
                />
              </div>
              <div class="p-5 flex flex-col flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-[0.6rem] uppercase tracking-[0.18em] font-bold text-acc-violet">
                    Research · {p.date}
                  </span>
                </div>
                <h3 class="text-base lg:text-lg font-semibold text-text dark:text-dk-text leading-snug mb-2">
                  {cleanTitle(p.title)}
                </h3>
                <p class="text-xs lg:text-sm text-text/60 dark:text-dk-text/65 leading-relaxed mb-4 line-clamp-3">
                  {p.description}
                </p>
                <div class="flex flex-wrap gap-1 mt-auto mb-3">
                  {(p.tech?.slice(0, 5) || []).map((t: string) => (
                    <span class="text-[0.62rem] uppercase tracking-[0.1em] px-1.5 py-0.5 rounded-full bg-text/5 dark:bg-dk-text/[0.06] text-text/60 dark:text-dk-text/65">
                      {t}
                    </span>
                  ))}
                </div>
                {p.link && (
                  <a
                    href={p.link}
                    target="_blank"
                    rel="noreferrer"
                    class="link-underline text-xs font-semibold text-acc-violet inline-flex mt-1"
                  >
                    View project <span aria-hidden="true">↗</span>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Band C: Academic ───────────────────────────────────────────── -->
  {academic.length > 0 && (
    <section class="snap-chapter relative py-24 lg:py-32">
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="max-w-3xl mb-12 lg:mb-16">
          <p class="eyebrow text-text/60 dark:text-dk-text/60 mb-4">Academic</p>
          <h2 class="display-sm text-text dark:text-dk-text glow-wave mb-4">
            From the NYU days.
          </h2>
          <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed">
            Grad-school projects that earned their grade and taught me
            something I still use.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {academic.map((p: any) => (
            <article class="rounded-xl border border-text/10 dark:border-dk-text/15 bg-primary dark:bg-dk-primary/40 overflow-hidden flex flex-col hover:border-text/30 dark:hover:border-dk-text/25 transition">
              <div class="relative overflow-hidden">
                <Image
                  src={p.img_path}
                  alt={p.img_alt || p.title}
                  width={900}
                  height={500}
                  class="w-full aspect-[16/9] object-cover transition duration-500 hover:scale-[1.03]"
                />
              </div>
              <div class="p-5 flex flex-col flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-[0.6rem] uppercase tracking-[0.18em] font-bold text-text/50 dark:text-dk-text/50">
                    {p.date}
                  </span>
                </div>
                <h3 class="text-base lg:text-lg font-semibold text-text dark:text-dk-text leading-snug mb-2">
                  {cleanTitle(p.title)}
                </h3>
                <p class="text-xs lg:text-sm text-text/60 dark:text-dk-text/65 leading-relaxed mb-4 line-clamp-3">
                  {p.description}
                </p>
                <div class="flex flex-wrap gap-1 mt-auto mb-3">
                  {(p.tech?.slice(0, 5) || []).map((t: string) => (
                    <span class="text-[0.62rem] uppercase tracking-[0.1em] px-1.5 py-0.5 rounded-full bg-text/5 dark:bg-dk-text/[0.06] text-text/60 dark:text-dk-text/65">
                      {t}
                    </span>
                  ))}
                </div>
                {p.link && (
                  <a
                    href={p.link}
                    target="_blank"
                    rel="noreferrer"
                    class="link-underline text-xs font-semibold text-secondary dark:text-dk-secondary inline-flex w-fit"
                  >
                    Open <span aria-hidden="true">→</span>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Band D: Read the deep dives (related blog posts) ──────────── -->
  {projectsWithBlog.length > 0 && (
    <section class="snap-chapter relative py-24 lg:py-32 bg-text/[0.02] dark:bg-dk-text/[0.03]">
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="max-w-3xl mb-12 lg:mb-16">
          <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">
            Long form
          </p>
          <h2 class="display-sm text-text dark:text-dk-text glow-wave mb-4">
            Read the deep dives.
          </h2>
          <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed">
            Full write-ups on the systems above. Failure modes, numbers, and
            the decisions that didn't make the bullet list.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {projectsWithBlog.map(({ p, post }: any) => (
            <a
              href={post}
              class="no-lift group rounded-xl border border-text/10 dark:border-dk-text/15 bg-primary dark:bg-dk-primary/40 p-5 flex flex-col hover:border-secondary/45 dark:hover:border-dk-secondary/55 transition"
            >
              <span class="text-[0.6rem] uppercase tracking-[0.18em] font-bold text-secondary dark:text-dk-secondary mb-2">
                Deep dive
              </span>
              <h3 class="text-base lg:text-lg font-semibold text-text dark:text-dk-text leading-snug mb-2 group-hover:text-secondary dark:group-hover:text-dk-secondary transition">
                {cleanTitle(p.title)}
              </h3>
              <p class="text-xs lg:text-sm text-text/60 dark:text-dk-text/65 leading-relaxed mb-4 line-clamp-3">
                {p.description}
              </p>
              <span class="mt-auto text-xs font-semibold text-secondary dark:text-dk-secondary inline-flex items-center gap-1.5">
                Read post <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Closer ─────────────────────────────────────────────────────── -->
  <section class="snap-chapter relative py-24 lg:py-32">
    <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 text-center">
      <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">
        That's the work
      </p>
      <h2 class="text-3xl lg:text-4xl font-semibold tracking-tight text-text dark:text-dk-text mb-6">
        Let's build something.
      </h2>
      <p class="text-base lg:text-lg text-text/65 dark:text-dk-text/70 max-w-2xl mx-auto leading-relaxed mb-8">
        Hiring for applied AI, forward-deployed-style work, or anything in
        between? I'd love to hear what you're working on.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/posts"
          class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 bg-text text-primary dark:bg-dk-text dark:text-dk-primary text-sm font-semibold hover:opacity-85 transition"
        >
          Read the writing <span aria-hidden="true">→</span>
        </a>
        <a
          href="/#contact"
          class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 border border-text/20 dark:border-dk-text/20 text-sm font-semibold text-text dark:text-dk-text hover:bg-text/5 dark:hover:bg-dk-text/10 transition"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Hero atmosphere. Same faint single-bloom pattern as the chapter and
     project-screen atmos so the page reads as one continuous black/matte
     gray surface; the eyebrow-blue colour stays in the glow only. */
  .projects-hero-atmos {
    position: relative;
  }
  .projects-hero-atmos::before {
    content: "";
    position: absolute;
    inset: -5%;
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(91, 141, 239, 0.10) 0%, rgba(91, 141, 239, 0.05) 40%, rgba(91, 141, 239, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(91, 141, 239, 0.07) 0%, rgba(91, 141, 239, 0.035) 40%, rgba(91, 141, 239, 0) 74%);
    z-index: 0;
    pointer-events: none;
    will-change: transform;
    transform: translateZ(0);
    animation: atmosDrift 22s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .projects-hero-atmos::before { animation: none; will-change: auto; }
  }

  /* Each Hybridge deep dive: full-viewport flex column with breathing room. */
  .project-screen {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: clamp(5rem, 8vh, 7rem);
    padding-bottom: clamp(4rem, 7vh, 6rem);
  }

  /* No per-screen bg fills. Every project sits on the body bg so the only
     colour cue is the per-project atmos glow. */

  .project-screen-atmos {
    position: absolute;
    inset: -5%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.55;
    will-change: transform;
    transform: translateZ(0);
    animation: atmosDrift 24s ease-in-out infinite;
  }
  /* Each variant matches the ambient colour of that project's hero image
     so the glow reads as a faint echo of the screenshot, never a wash. */
  .project-screen-atmos.atmos-cyan {
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(34, 211, 238, 0.10) 0%, rgba(34, 211, 238, 0.05) 40%, rgba(34, 211, 238, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(34, 211, 238, 0.07) 0%, rgba(34, 211, 238, 0.035) 40%, rgba(34, 211, 238, 0) 74%);
  }
  .project-screen-atmos.atmos-violet {
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(167, 139, 250, 0.10) 0%, rgba(167, 139, 250, 0.05) 40%, rgba(167, 139, 250, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(167, 139, 250, 0.07) 0%, rgba(167, 139, 250, 0.035) 40%, rgba(167, 139, 250, 0) 74%);
  }
  .project-screen-atmos.atmos-blue {
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(91, 141, 239, 0.10) 0%, rgba(91, 141, 239, 0.05) 40%, rgba(91, 141, 239, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(91, 141, 239, 0.07) 0%, rgba(91, 141, 239, 0.035) 40%, rgba(91, 141, 239, 0) 74%);
  }
  .project-screen-atmos.atmos-emerald {
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(52, 211, 153, 0.10) 0%, rgba(52, 211, 153, 0.05) 40%, rgba(52, 211, 153, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(52, 211, 153, 0.07) 0%, rgba(52, 211, 153, 0.035) 40%, rgba(52, 211, 153, 0) 74%);
  }
  .project-screen-atmos.atmos-amber {
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(245, 165, 36, 0.10) 0%, rgba(245, 165, 36, 0.05) 40%, rgba(245, 165, 36, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(245, 165, 36, 0.07) 0%, rgba(245, 165, 36, 0.035) 40%, rgba(245, 165, 36, 0) 74%);
  }
  .project-screen-atmos.atmos-slate {
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(148, 163, 184, 0.10) 0%, rgba(148, 163, 184, 0.05) 40%, rgba(148, 163, 184, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(148, 163, 184, 0.07) 0%, rgba(148, 163, 184, 0.035) 40%, rgba(148, 163, 184, 0) 74%);
  }

  /* Light-mode: lift the screen with a soft pastel wash + deeper stat
     accents. Keep the same shape as dark mode, just calibrated for white. */
  html:not(.dark) .project-screen-atmos { opacity: 0.85; }
  html:not(.dark) .project-screen-atmos.atmos-cyan {
    background:
      radial-gradient(ellipse 72% 59% at 22% 32%, rgba(34, 211, 238, 0.22) 0%, rgba(34, 211, 238, 0.11) 38%, rgba(34, 211, 238, 0) 74%),
      radial-gradient(ellipse 72% 59% at 78% 72%, rgba(34, 211, 238, 0.15) 0%, rgba(34, 211, 238, 0.075) 38%, rgba(34, 211, 238, 0) 74%);
  }
  html:not(.dark) .project-screen-atmos.atmos-violet {
    background:
