---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/projects_section/ProjectCard";
import { info } from "../data/info";

const title = "SA: Projects";
---

<BaseLayout title={title}>
  <div class="mx-auto w-full max-w-screen-2xl px-4 sm:px-6 lg:px-10 xl:px-14 2xl:px-20">
    <section class="mt-24 reveal" data-reveal>
      <p class="eyebrow text-secondary dark:text-dk-secondary mb-3">Selected work</p>
      <h1 class="display-sm mb-10">Projects.</h1>
      <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 items-stretch">
        {info.projects.map((project) => (
          <ProjectCard project={project} client:only />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
