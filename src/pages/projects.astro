<script>
  // Toggle the .is-flipped class on each [data-flip-card] when clicked.
  // Lightweight and progressive: no JS, no flip.
  document.querySelectorAll<HTMLElement>("[data-flip-card]").forEach((card) => {
    card.addEventListener("click", () => {
      card.classList.toggle("is-flipped");
      const flipped = card.classList.contains("is-flipped");
      card.setAttribute(
        "aria-label",
        flipped ? "Hide case study" : "Show case study",
      );
    });
  });
</script>
