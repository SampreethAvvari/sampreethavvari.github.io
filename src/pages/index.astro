---
import BaseLayout from "../layouts/BaseLayout.astro";
import { info } from "../data/info";
import Contact from "../components/contact_section/Contact";
import { Image } from "astro:assets";

const allPosts = await Astro.glob("../pages/posts/*.md");
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).getTime() -
      new Date(a.frontmatter.date).getTime(),
  )
  .slice(0, 4);

// The five Hybridge systems, in display order on the home strip.
const systems = [
  {
    n: "01",
    name: "Consultation QA Pipeline",
    tagline:
      "Zoom transcript turns into a color-coded coaching report in 5–15 minutes. Schema-validated Vertex AI Gemini, no Workspace DWD required.",
    metric: "+130%",
    metricLabel: "treatment acceptance",
    accent: "#34D399",
    href: "/posts/clinical-rag",
  },
  {
    n: "02",
    name: "CBCT Scan Validator",
    tagline:
      "In-house dental-CT classifier on Cloud Run that replaced a $98K + $26K/yr vendor quote with a sub-$50/month service.",
    metric: "$50/mo",
    metricLabel: "vs $124K year-one quote",
    accent: "#22D3EE",
    href: "/posts/cbct-scan-validator",
  },
  {
    n: "03",
    name: "Treatment Estimator",
    tagline:
      "A Postgres BEFORE-UPDATE trigger that turns the 6-month price guarantee into a database invariant. Shipped in about a month, after a decade of attempts that never made it out the door.",
    metric: "1 month",
    metricLabel: "vs the 10-year vendor attempt that never shipped",
    accent: "#A78BFA",
    href: "/posts/treatment-estimator",
  },
  {
    n: "04",
    name: "Cowork Dashboard",
    tagline:
      "The Monday connect column took patient-to-lead linkage from 49% to 99% and surfaced six figures of orphan re-treatment revenue.",
    metric: "$169k",
    metricLabel: "of revenue surfaced",
    accent: "#5B8DEF",
    href: "/posts/cowork-dashboard",
  },
  {
    n: "05",
    name: "Accounting Automation",
    tagline:
      "A dozen Python scripts replaced the controller's manual weekly import-reformat-paste loop across Denticon, MagicTouch, Paychex, and two banks.",
    metric: "~400h",
    metricLabel: "of senior time saved per year",
    accent: "#F5A524",
    href: "/posts/accounting-automation",
  },
];

const filmCredits = [
  { title: "Among Monsters", year: "2026", role: "Director · Writer · Editor · Music" },
  { title: "Extraordinary Lives", year: "upcoming", role: "Director · Writer" },
  { title: "Tiger Man", year: "2022", role: "Director · Writer · Editor" },
  { title: "Strangers", year: "2019", role: "Cinematographer · Music" },
];
---

<BaseLayout title="Sampreeth Avvari">
  <script is:inline>
    document.documentElement.classList.add("snap-home");
  </script>
  <div class="home-aurora" aria-hidden="true"></div>
  <div class="snap-chapters">

    <!-- ── Chapter 1: Hero ───────────────────────────────────────────────── -->
    <section
      class="chapter snap-chapter relative landing-atmos overflow-hidden"
      id="home"
    >
      <div
        class="relative z-10 mx-auto w-full max-w-screen-2xl px-6 lg:px-12 grid lg:grid-cols-12 items-center gap-12"
      >
        <div class="lg:col-span-5 flex justify-center lg:justify-start">
          <div class="relative floaty">
            <div
              class="absolute -inset-8 rounded-full bg-gradient-to-br from-acc-blue/40 via-acc-violet/25 to-acc-cyan/40 blur-3xl opacity-70 pointer-events-none animate-pulse"
              style="animation-duration: 6s;"
            ></div>
            <div class="relative rounded-full photo-shimmer">
              <Image
                src={info.picture}
                alt={info.picture_alt}
                width={420}
                height={420}
                class="relative lg:h-80 lg:w-80 xl:h-[22rem] xl:w-[22rem] h-48 w-48 rounded-full object-cover ring-1 ring-text/10 dark:ring-dk-text/15"
              />
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 flex flex-col gap-6 text-center lg:text-left">
          <p
            class="eyebrow text-text/60 dark:text-dk-text/60"
          >
            AI Engineer · New York
          </p>
          <h1 class="display text-text dark:text-dk-text glow-wave">
            Hi, I'm <span class="text-secondary dark:text-dk-secondary text-shimmer">Sampreeth.</span>
          </h1>
          <p class="text-xl lg:text-2xl text-text/75 dark:text-dk-text/75 leading-relaxed glow-wave glow-delay-2">
            I ship ML systems in the room with the people using them.
          </p>
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 pt-2">
            <a
              href="#work"
              class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 bg-text text-primary dark:bg-dk-text dark:text-dk-primary text-sm font-semibold hover:opacity-85 transition"
            >
              See the work <span aria-hidden="true">↓</span>
            </a>
            <a
              href="/posts"
              class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 border border-text/20 dark:border-dk-text/20 text-sm font-semibold text-text dark:text-dk-text hover:bg-text/5 dark:hover:bg-dk-text/10 transition"
            >
              Read the writing
            </a>
            <a
              href="#contact"
              class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-text/70 dark:text-dk-text/70 hover:text-secondary dark:hover:text-dk-secondary transition"
            >
              Get in touch
            </a>
          </div>
        </div>
      </div>

      <a
        href="#work"
        aria-label="Scroll"
        class="no-lift absolute bottom-8 left-1/2 -translate-x-1/2 text-text/40 dark:text-dk-text/40 hover:text-text dark:hover:text-dk-text transition animate-pulse"
      >
        <i class="fas fa-chevron-down text-xl"></i>
      </a>
    </section>

    <!-- ── Chapter 2: The work ───────────────────────────────────────────── -->
    <section
      class="chapter snap-chapter bg-text/[0.02] dark:bg-dk-text/[0.03]"
      id="work"
    >
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="max-w-4xl reveal" data-reveal>
          <p class="eyebrow text-secondary dark:text-dk-secondary mb-3">
            01 — The work
          </p>
          <h2 class="display-sm text-text dark:text-dk-text mb-3 glow-wave">
            Five systems, inside a dental practice.
          </h2>
          <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed max-w-2xl">
            Production AI built alongside the senior coordinator, the
            controller, the validation team, the CEO. The systems I'm
            proudest of are the ones that survived that contact.
          </p>
        </div>

        <ul class="mt-8 lg:mt-12 divide-y divide-text/10 dark:divide-dk-text/10 reveal" data-reveal>
          {systems.map((s) => (
            <li>
              <a
                href={s.href}
                class="no-lift group flex flex-col lg:flex-row lg:items-center gap-3 lg:gap-8 py-4 lg:py-5 transition"
              >
                <span
                  class="font-mono text-sm font-semibold tabular-nums w-10 shrink-0 text-text/40 dark:text-dk-text/40"
                >
                  {s.n}
                </span>
                <div class="flex-1 min-w-0">
                  <h3
                    class="text-xl lg:text-2xl font-semibold tracking-tight text-text dark:text-dk-text group-hover:text-secondary dark:group-hover:text-dk-secondary transition"
                  >
                    {s.name}
                  </h3>
                  <p class="mt-0.5 text-sm text-text/65 dark:text-dk-text/65 leading-snug max-w-3xl line-clamp-2">
                    {s.tagline}
                  </p>
                </div>
                <div class="lg:text-right lg:min-w-[9rem] shrink-0">
                  <div
                    class="text-xl lg:text-2xl font-semibold tabular-nums tracking-tight"
                    style={`color: ${s.accent};`}
                  >
                    {s.metric}
                  </div>
                  <div class="text-[0.65rem] uppercase tracking-[0.18em] text-text/45 dark:text-dk-text/45 mt-0.5">
                    {s.metricLabel}
                  </div>
                </div>
                <span
                  class="text-text/40 dark:text-dk-text/40 group-hover:text-secondary dark:group-hover:text-dk-secondary group-hover:translate-x-1 transition-transform"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-10 flex items-center justify-between flex-wrap gap-4">
          <a
            href="/projects"
            class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary"
          >
            Browse all 13 projects <span aria-hidden="true">→</span>
          </a>
          <p class="text-xs text-text/40 dark:text-dk-text/40">
            Scroll for the rest of the story
          </p>
        </div>
      </div>
    </section>

    <!-- ── Chapter 3: About ──────────────────────────────────────────────── -->
    <section class="chapter snap-chapter" id="about">
      <div
        class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16 items-center"
      >
        <div class="lg:col-span-6 reveal" data-reveal>
          <p class="eyebrow text-secondary dark:text-dk-secondary mb-5">
            02 — About
          </p>
          <h2 class="display text-text dark:text-dk-text mb-8 glow-wave">
            An engineer who happens to <span class="text-secondary dark:text-dk-secondary">make movies</span>.
          </h2>
          <p class="text-base lg:text-lg text-text/75 dark:text-dk-text/75 leading-relaxed max-w-xl">
            {info.about.description}
          </p>
          <div class="mt-8 flex flex-wrap gap-2.5">
            {[
              { t: "Python", c: "p1" },
              { t: "TypeScript", c: "p2" },
              { t: "FastAPI", c: "p3" },
              { t: "Next.js", c: "p4" },
              { t: "PyTorch", c: "p5" },
              { t: "Vertex AI", c: "p6" },
              { t: "Cloud Run", c: "p7" },
              { t: "Postgres", c: "p8" },
              { t: "Drizzle", c: "p9" },
              { t: "MLflow", c: "p10" },
            ].map((p) => (
              <span class={`skill-pill ${p.c}`}>{p.t}</span>
            ))}
          </div>
        </div>

        <div class="lg:col-span-6 reveal" data-reveal>
          <div class="grid sm:grid-cols-2 gap-6 lg:gap-8">
            <div>
              <p class="eyebrow text-secondary/80 dark:text-dk-secondary/80 mb-5">
                Education
              </p>
              <ul class="space-y-4">
                {info.about.education.map((ed) => (
                  <li class="timeline-row text-sm">
                    <div class={`timeline-logo ${ed.logo ? "" : "logo-placeholder"}`}>
                      {ed.logo ? (
                        <img src={ed.logo} alt={`${ed.location} logo`} />
                      ) : (
                        <span>JNTU</span>
                      )}
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-text dark:text-dk-text leading-snug">
                        {ed.title}
                      </p>
                      <p class="text-text/60 dark:text-dk-text/60 leading-snug">
                        {ed.location}
                      </p>
                      <p class="text-text/40 dark:text-dk-text/40 text-xs mt-1">
                        {ed.date}{ed.gpa ? ` · GPA ${ed.gpa}` : ""}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="eyebrow text-acc-amber/90 mb-5">
                Experience
              </p>
              <ul class="space-y-4">
                {info.about.experience.map((ex) => (
                  <li class="timeline-row text-sm">
                    <div class={`timeline-logo ${ex.logo ? "" : "logo-placeholder"}`}>
                      {ex.logo ? (
                        <img src={ex.logo} alt={`${ex.location} logo`} />
                      ) : (
                        <span>{ex.location.split(",")[0].slice(0, 2).toUpperCase()}</span>
                      )}
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-text dark:text-dk-text leading-snug">
                        {ex.title}
                      </p>
                      <p class="text-text/60 dark:text-dk-text/60 leading-snug">
                        {ex.location}
                      </p>
                      <p class="text-text/40 dark:text-dk-text/40 text-xs mt-1">
                        {ex.date}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <a
            href="/projects"
            class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary mt-8 inline-flex"
          >
            See all the projects <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Chapter 4: Writing ────────────────────────────────────────────── -->
    <section class="chapter snap-chapter" id="writing">
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="flex items-end justify-between mb-10 reveal" data-reveal>
          <div>
            <p class="eyebrow text-acc-emerald dark:text-acc-emerald mb-4">
              03 — Writing
            </p>
            <h2 class="display-sm text-text dark:text-dk-text glow-wave">
              Notes from <span class="text-acc-emerald">the work</span>.
            </h2>
            <p class="mt-4 text-base lg:text-lg text-text/65 dark:text-dk-text/70 leading-relaxed max-w-2xl">
              Long-form posts from production systems I've shipped. Real numbers, real failure modes, real fixes.
            </p>
          </div>
          <a
            href="/posts"
            class="link-underline text-sm font-semibold text-acc-emerald hidden lg:inline-flex"
          >
            All posts <span aria-hidden="true">→</span>
          </a>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 reveal"
          data-reveal
        >
          {latestPosts.map((post, i) => {
            const accents = ["blue", "emerald", "violet", "amber"];
            const accent = accents[i % accents.length];
            return (
              <a
                href={post.url}
                class={`no-lift post-card post-card-accent-${accent} group flex flex-col`}
              >
                {post.frontmatter.img_path && (
                  <div class="relative overflow-hidden">
                    <Image
                      src={post.frontmatter.img_path}
                      alt={post.frontmatter.img_alt || post.frontmatter.title}
                      width={600}
                      height={320}
                      class="w-full h-44 object-cover transition duration-500 group-hover:scale-[1.04]"
                    />
                    {i === 0 && (
                      <span class="absolute top-3 right-3 featured-badge text-[0.62rem]">
                        Latest
                      </span>
                    )}
                  </div>
                )}
                <div class="p-5 flex flex-col gap-2.5 flex-1">
                  <p class="text-[0.68rem] uppercase tracking-[0.16em] font-semibold text-text/45 dark:text-dk-text/45 tabular-nums">
                    {post.frontmatter.date}
                  </p>
                  <h3 class="text-[0.98rem] font-semibold text-text dark:text-dk-text leading-snug line-clamp-3 group-hover:text-secondary dark:group-hover:text-dk-secondary transition">
                    {post.frontmatter.title}
                  </h3>
                  <p class="text-xs text-text/60 dark:text-dk-text/65 leading-relaxed line-clamp-3 mt-auto">
                    {post.frontmatter.description}
                  </p>
                </div>
              </a>
            );
          })}
        </div>

        <a
          href="/posts"
          class="link-underline text-sm font-semibold text-acc-emerald mt-8 inline-flex lg:hidden"
        >
          All posts <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- ── Chapter 5: Filmmaking ─────────────────────────────────────────── -->
    <section
      class="chapter snap-chapter bg-text/[0.03] dark:bg-dk-text/[0.04]"
      id="filmmaking"
    >
      <div
        class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 grid lg:grid-cols-12 gap-12 items-center"
      >
        <div class="lg:col-span-6 reveal" data-reveal>
          <p class="eyebrow text-acc-amber dark:text-acc-amber mb-4">
            04 — Filmmaking
          </p>
          <h2 class="display-sm text-text dark:text-dk-text mb-6 glow-wave">
            "Gray characters, <span class="text-acc-amber">tight spaces</span>, and the chaos hiding inside ordinary lives."
          </h2>
          <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed mb-8 max-w-xl">
            I write, direct, edit, and score. <em class="not-italic font-semibold text-text dark:text-dk-text">Among Monsters</em> is the independent feature I'm cutting between work weeks. The way I work alongside non-engineers, I learned on film sets first.
          </p>
          <div class="flex flex-wrap items-center gap-3">
            <a
              href="https://www.imdb.com/title/tt39700295/"
              target="_blank"
              rel="noreferrer"
              class="no-lift inline-flex items-center gap-2 rounded-full px-5 py-2.5 bg-text text-primary dark:bg-dk-text dark:text-dk-primary text-sm font-semibold hover:opacity-85 transition"
            >
              Among Monsters on IMDb <span aria-hidden="true">↗</span>
            </a>
            <a
              href="/filmmaking"
              class="no-lift inline-flex items-center gap-2 rounded-full px-5 py-2.5 border border-text/20 dark:border-dk-text/20 text-sm font-semibold text-text dark:text-dk-text hover:bg-text/5 dark:hover:bg-dk-text/10 transition"
            >
              See the full slate
            </a>
          </div>
        </div>

        <div class="lg:col-span-6 reveal" data-reveal>
          <ul class="space-y-0.5">
            {filmCredits.map((c, i) => (
              <li class="group flex items-center justify-between gap-4 py-3.5 border-b border-text/10 dark:border-dk-text/10 hover:border-text/30 dark:hover:border-dk-text/25 transition">
                <div class="min-w-0 flex items-center gap-4">
                  <span class="font-mono text-[0.7rem] text-text/35 dark:text-dk-text/40 tabular-nums w-7 shrink-0">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <div class="min-w-0">
                    <p class="text-lg lg:text-xl font-semibold text-text dark:text-dk-text group-hover:text-acc-amber transition truncate">
                      {c.title}
                    </p>
                    <p class="mt-0.5 text-[0.72rem] uppercase tracking-[0.16em] text-text/50 dark:text-dk-text/55 font-medium">
                      {c.role}
                    </p>
                  </div>
                </div>
                <span class="font-mono text-lg lg:text-xl font-semibold text-text/40 dark:text-dk-text/45 group-hover:text-acc-amber tabular-nums shrink-0 transition">
                  {c.year}
                </span>
              </li>
            ))}
          </ul>
          <a
            href="/filmmaking"
            class="link-underline text-sm font-semibold text-acc-amber mt-6 inline-flex"
          >
            All credits, stills, and crew <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Chapter 6: Connect ────────────────────────────────────────────── -->
    <section
      class="chapter snap-chapter bg-text/[0.02] dark:bg-dk-text/[0.03]"
      id="contact"
    >
      <div
        class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 text-center reveal"
        data-reveal
      >
        <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">
          05 — Connect
        </p>
        <h2 class="display text-text dark:text-dk-text mb-6">
          Let's build something.
        </h2>
        <p class="text-lg lg:text-xl text-text/70 dark:text-dk-text/70 max-w-2xl mx-auto leading-relaxed mb-10">
          Hiring for forward-deployed, applied AI, or anything in between?
          I'd love to hear what you're working on.
        </p>
        <a
          href={`mailto:${info.contact.email}`}
          class="no-lift inline-flex items-center gap-2 rounded-full px-7 py-4 bg-text text-primary dark:bg-dk-text dark:text-dk-primary text-base font-semibold hover:opacity-85 transition"
        >
          {info.contact.email} <span aria-hidden="true">→</span>
        </a>
        <div class="mt-12 flex justify-center">
          <Contact contact={info.contact} size="md" client:visible />
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
