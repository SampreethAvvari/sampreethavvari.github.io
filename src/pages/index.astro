<script>
  // Landing hero: CSS-var parallax + a 3D cursor-steered sphere of glowing
  // light points (the centrepiece "object") over ambient drift. Sprite-based
  // rendering keeps it smooth. All gated on reduced-motion.
  (function () {
    const hero = document.getElementById("home");
    if (!hero) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const bg = hero.querySelector(".hero-bg");
    const COLORS = [[52, 211, 153], [245, 165, 36], [167, 139, 250], [91, 141, 239]];

    // Pointer state, shared by parallax, the 3D tilt, and the sphere rotation.
    let mx = 0, my = 0, sy = 0;

    if (!reduce && window.matchMedia("(pointer: fine)").matches) {
      const layers = Array.from(hero.querySelectorAll("[data-parallax]"));
      let raf = 0;
      const apply = () => {
        raf = 0;
        for (const el of layers) {
          const f = parseFloat(el.getAttribute("data-parallax")) || 0;
          el.style.setProperty("--px", (mx * f * 120).toFixed(1) + "px");
          el.style.setProperty("--py", (my * f * 120 + sy * f * 0.5).toFixed(1) + "px");
        }
        if (bg) {
          bg.style.setProperty("--bg-rx", (mx * 6).toFixed(2) + "deg");
          bg.style.setProperty("--bg-ry", (-my * 6).toFixed(2) + "deg");
        }
      };
      const queue = () => { if (!raf) raf = requestAnimationFrame(apply); };
      window.addEventListener("mousemove", (e) => {
        mx = e.clientX / window.innerWidth - 0.5;
        my = e.clientY / window.innerHeight - 0.5;
        queue();
      }, { passive: true });
      window.addEventListener("scroll", () => { sy = window.scrollY; queue(); }, { passive: true });
    }

    const canvas = hero.querySelector("[data-hero-canvas]");
    if (!canvas || reduce) return;
    const ctx = canvas.getContext("2d");
    const isDark = () => document.documentElement.classList.contains("dark");

    // Tight glow sprite per colour (sharp core).
    const sprites = COLORS.map(([r, g, b]) => {
      const s = document.createElement("canvas"); s.width = s.height = 64;
      const c = s.getContext("2d");
      const gr = c.createRadialGradient(32, 32, 0, 32, 32, 32);
      gr.addColorStop(0, "rgba(" + r + "," + g + "," + b + ",1)");
      gr.addColorStop(0.35, "rgba(" + r + "," + g + "," + b + ",0.32)");
      gr.addColorStop(1, "rgba(" + r + "," + g + "," + b + ",0)");
      c.fillStyle = gr; c.fillRect(0, 0, 64, 64);
      return s;
    });

    // Dense point sphere; nearest-neighbour edges = the mesh. Each point keeps
    // its own cursor-pull displacement (cdx/cdy) so the bulge is localised.
    const N = 360;
    const pts = Array.from({ length: N }, (_, i) => {
      const yy = 1 - (i / (N - 1)) * 2;
      const rad = Math.sqrt(Math.max(0, 1 - yy * yy));
      const th = i * 2.399963229;
      return { x: Math.cos(th) * rad, y: yy, z: Math.sin(th) * rad, ci: i % COLORS.length, cdx: 0, cdy: 0 };
    });
    const edges = [];
    const seenE = new Set();
    for (let i = 0; i < N; i++) {
      const d = [];
      for (let j = 0; j < N; j++) {
        if (i === j) continue;
        const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y, dz = pts[i].z - pts[j].z;
        d.push([dx * dx + dy * dy + dz * dz, j]);
      }
      d.sort((a, b) => a[0] - b[0]);
      for (let k = 0; k < 6; k++) {
        const j = d[k][1], a = Math.min(i, j), b = Math.max(i, j), key = a + "-" + b;
        if (!seenE.has(key)) { seenE.add(key); edges.push([a, b]); }
      }
    }
    const pulses = Array.from({ length: 24 }, () => ({ e: (Math.random() * edges.length) | 0, t: Math.random(), sp: 0.004 + Math.random() * 0.01 }));

    let W = 0, H = 0, dpr = 1, cx = 0, cy = 0, radius = 0, t = 0, vis = true;
    let angY = 0, angX = 0, curX = 0, curY = 0, curOn = false;
    const proj = new Array(N);

    const aim = (e) => {
      const r = canvas.getBoundingClientRect();
      curX = e.clientX - r.left; curY = e.clientY - r.top; curOn = true;
    };
    const release = () => { curOn = false; };
    // Mouse AND touch: pointermove drives the bulge on desktop; pointerdown +
    // up/cancel make a finger drag work on mobile (touch-action: pan-y keeps
    // vertical scrolling intact while the sphere still tracks the finger).
    canvas.addEventListener("pointermove", aim, { passive: true });
    canvas.addEventListener("pointerdown", aim, { passive: true });
    canvas.addEventListener("pointerup", release, { passive: true });
    canvas.addEventListener("pointercancel", release, { passive: true });
    canvas.addEventListener("pointerleave", release, { passive: true });

    function size() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth; H = canvas.clientHeight;
      canvas.width = Math.max(1, W * dpr); canvas.height = Math.max(1, H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cx = W / 2; cy = H * (W < 1024 ? 0.64 : 0.48);  // drop low on mobile (where the photo used to sit)
      radius = Math.min(W, H) * (W < 1024 ? 0.26 : 0.205);
    }
    function frame() {
      requestAnimationFrame(frame);
      if (!vis || !W) return;
      t += 0.0022;
      angY += 0.0016;                 // gentle constant spin, no cursor rotation
      angX = Math.sin(t * 0.5) * 0.1; // slow wobble for life
      const dark = isDark();
      ctx.clearRect(0, 0, W, H);
      ctx.globalCompositeOperation = dark ? "lighter" : "source-over";

      const cosY = Math.cos(angY), sinY = Math.sin(angY), cosX = Math.cos(angX), sinX = Math.sin(angX);
      const infl = Math.min(W, H) * 0.26;   // radius of the cursor's gravity well
      for (let i = 0; i < N; i++) {
        const p = pts[i];
        let x = p.x * cosY - p.z * sinY;
        let z = p.x * sinY + p.z * cosY;
        const y = p.y * cosX - z * sinX;
        z = p.y * sinX + z * cosX;
        const persp = 1.7 / (1.7 - z);
        const depth = (z + 1) / 2;
        const bx = cx + x * radius * persp, by = cy + y * radius * persp;
        // Localised pull: only front-facing points inside the influence radius
        // are drawn toward the cursor, with a smooth falloff — a tidal bulge
        // that follows the cursor. The rest of the sphere stays put.
        let tdx = 0, tdy = 0;
        if (curOn && depth > 0.4) {
          const dx = curX - bx, dy = curY - by, dist = Math.hypot(dx, dy) || 1;
          if (dist < infl) {
            let f = 1 - dist / infl; f *= f * (3 - 2 * f); // smoothstep falloff
            const pull = f * infl * 0.52;
            tdx = (dx / dist) * pull; tdy = (dy / dist) * pull;
          }
        }
        // snappy but fluid spring toward the target displacement
        p.cdx += (tdx - p.cdx) * 0.2;
        p.cdy += (tdy - p.cdy) * 0.2;
        const lift = Math.min(1, Math.hypot(p.cdx, p.cdy) / (infl * 0.45));
        proj[i] = { sx: bx + p.cdx, sy: by + p.cdy, depth, persp, lift };
      }
      for (let e = 0; e < edges.length; e++) {
        const pa = proj[edges[e][0]], pb = proj[edges[e][1]];
        const dep = (pa.depth + pb.depth) / 2;
        const lift = pa.lift > pb.lift ? pa.lift : pb.lift;
        const col = COLORS[pts[edges[e][0]].ci];
        ctx.strokeStyle = "rgba(" + col[0] + "," + col[1] + "," + col[2] + "," + (((dark ? 0.08 : 0.06) + dep * 0.12) * (1 + lift * 2.4)).toFixed(3) + ")";
        ctx.lineWidth = 0.5 + dep * 0.5 + lift * 0.8;
        ctx.beginPath(); ctx.moveTo(pa.sx, pa.sy); ctx.lineTo(pb.sx, pb.sy); ctx.stroke();
      }
      for (const pu of pulses) {
        pu.t += pu.sp;
        if (pu.t > 1) { pu.t = 0; pu.e = (Math.random() * edges.length) | 0; }
        const pa = proj[edges[pu.e][0]], pb = proj[edges[pu.e][1]];
        const px = pa.sx + (pb.sx - pa.sx) * pu.t, py = pa.sy + (pb.sy - pa.sy) * pu.t;
        const R = 4.5 * ((pa.depth + pb.depth) / 2 + 0.3);
        ctx.globalAlpha = dark ? 0.8 : 0.55;
        ctx.drawImage(sprites[pts[edges[pu.e][0]].ci], px - R, py - R, R * 2, R * 2);
      }
      ctx.globalAlpha = 1;
      for (let i = 0; i < N; i++) {
        const pr = proj[i];
        const R = (1.8 + pr.depth * 4.5) * pr.persp * (1 + pr.lift * 1.9);
        ctx.globalAlpha = Math.min(1, ((dark ? 0.16 : 0.14) + pr.depth * (dark ? 0.5 : 0.42)) * (1 + pr.lift * 1.8));
        ctx.drawImage(sprites[pts[i].ci], pr.sx - R, pr.sy - R, R * 2, R * 2);
        const col = COLORS[pts[i].ci];
        ctx.globalAlpha = Math.min(1, (0.4 + pr.depth * 0.5) * (1 + pr.lift));
        ctx.fillStyle = dark ? "rgba(255,255,255," + (0.4 + pr.depth * 0.4).toFixed(2) + ")" : "rgba(" + col[0] + "," + col[1] + "," + col[2] + ",0.85)";
        ctx.beginPath(); ctx.arc(pr.sx, pr.sy, Math.max(0.5, pr.depth * 1.5), 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalAlpha = 1;
    }
    size();
    window.addEventListener("resize", size, { passive: true });
    document.addEventListener("visibilitychange", () => { vis = !document.hidden; });
    frame();
  })();
</script>

<style>
  /* Hero discipline chips — equal accent pills replacing the piped acronyms.
     Each carries its discipline colour via --dx / --dx-rgb set inline. */
  .dx-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.9rem;
    border-radius: 9999px;
    font-family: "SF Mono", "JetBrains Mono", Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1;
    color: rgb(29 29 31 / 0.7);
    border: 1px solid rgba(var(--dx-rgb), 0.28);
    background: rgba(var(--dx-rgb), 0.06);
    -webkit-backdrop-filter: blur(10px) saturate(150%);
    backdrop-filter: blur(10px) saturate(150%);
    transition: color 0.25s ease, border-color 0.25s ease, background 0.25s ease,
      transform 0.25s ease, box-shadow 0.25s ease;
  }
  :global(html.dark) .dx-pill {
    color: rgb(245 245 247 / 0.72);
  }
  .dx-pill-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: var(--dx);
    box-shadow: 0 0 8px color-mix(in srgb, var(--dx) 60%, transparent);
    flex: 0 0 auto;
  }
  .dx-pill:hover {
    color: var(--dx);
    border-color: rgba(var(--dx-rgb), 0.6);
    background: rgba(var(--dx-rgb), 0.12);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -10px rgba(var(--dx-rgb), 0.55);
  }
  .dx-pill:focus-visible {
    outline: 2px solid rgba(var(--dx-rgb), 0.6);
    outline-offset: 3px;
  }
</style>
