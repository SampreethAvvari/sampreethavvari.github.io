    <span class="glow glow-2" style="width:450px;height:450px;--gc:#22D3EE;bottom:-80px;right:12%;" aria-hidden="true"></span>
    <span class="space-el" style="width:143px;height:38px;top:14%;left:8%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:91,141,239;"></span><span class="space-comet" style="--sr-rgb:91,141,239;--rz:-12deg;"></span></span>
    <span class="space-el" style="width:117px;height:33px;bottom:12%;right:9%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:34,211,238;"></span><span class="space-comet" style="--sr-rgb:34,211,238;--rz:10deg;"></span></span>
    <div class="relative z-[1] mx-auto w-full max-w-screen-2xl px-6 lg:px-12" data-arrive>
      <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">06 · Connect</p>
      <h2 class="display text-text dark:text-dk-text mb-5">
        Let's build <span class="text-secondary dark:text-dk-secondary">something</span>.
      </h2>
      <p class="text-lg lg:text-xl text-text/70 dark:text-dk-text/70 max-w-2xl mx-auto leading-relaxed mb-10">
        Hiring for forward-deployed, applied AI, or anything in between? I'd love to hear what you're working on.
      </p>
      <a
        href={`mailto:${info.contact.email}`}
        class="no-lift pane pane-glare inline-flex items-center gap-3 px-8 py-5 text-lg lg:text-xl font-bold tracking-tight text-text dark:text-dk-text"
        data-magnetic
        style="border-radius: 9999px;"
      >
        <Icon name="mail" size={20} class="text-secondary dark:text-dk-secondary" />
