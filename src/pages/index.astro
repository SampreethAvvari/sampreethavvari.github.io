                <h3 class="text-base lg:text-lg font-bold tracking-tight text-text dark:text-dk-text leading-snug line-clamp-2 group-hover:text-secondary dark:group-hover:text-dk-secondary transition">
                  {post.frontmatter.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </div>

      <a href="/posts" class="link-underline text-sm font-semibold text-acc-emerald mt-8 inline-flex lg:hidden items-center gap-1.5">
        All posts <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </section>

  <!-- ── Filmmaking ───────────────────────────────────────────────────── -->
  <section id="filmmaking" class="relative overflow-hidden py-24 lg:py-32">
    <span class="glow" style="width:630px;height:630px;--gc:#F43F5E;top:-90px;right:-130px;" aria-hidden="true"></span>
    <span class="glow glow-2" style="width:480px;height:480px;--gc:#F43F5E;bottom:-70px;left:-60px;" aria-hidden="true"></span>
    <span class="space-el" style="width:163px;height:40px;top:10%;left:4%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:244,63,94;"></span><span class="space-comet" style="--sr-rgb:244,63,94;--rz:14deg;"></span></span>
    <div class="relative z-[1] mx-auto w-full max-w-screen-2xl px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6" data-arrive>
        <p class="eyebrow text-acc-film mb-4">05 · Filmmaking</p>
        <h2 class="display-sm text-text dark:text-dk-text mb-6">
          "Gray characters, <span class="text-acc-film">tight spaces</span>, and the chaos hiding inside ordinary lives."
        </h2>
        <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed mb-8 max-w-xl">
          I write, direct, edit, and score. <em class="not-italic font-semibold text-text dark:text-dk-text">Among Monsters</em> is the independent feature I'm cutting between work weeks.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="https://www.imdb.com/title/tt39700295/"
            target="_blank"
            rel="noreferrer"
            class="no-lift gbtn-ghost"
            data-magnetic
          >
            <span class="imdb-wordmark">IMDb</span> Among Monsters <Icon name="arrow-up-right" size={14} />
          </a>
          <a href="/filmmaking" class="no-lift gbtn-ghost" data-magnetic>
            The full slate
          </a>
        </div>
      </div>

      <div class="lg:col-span-6" data-arrive>
        <ul class="list-none p-0 m-0">
          {filmCredits.map((c, i) => (
            <li class="group flex items-center justify-between gap-4 py-4 border-b border-text/10 dark:border-dk-text/10 hover:border-acc-film/60 transition-colors">
              <div class="min-w-0 flex items-center gap-4">
