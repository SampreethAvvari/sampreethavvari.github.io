</BaseLayout>

<script>
  import {
    initGlare,
    initTilt,
    initMagnetic,
    initArrive,
    initCountUps,
    initAmbient,
    initComets,
  } from "../scripts/spatial";

  initGlare(".pane-glare");
  initTilt("[data-tilt]");
  initMagnetic("[data-magnetic]");
  initArrive("[data-arrive]");
  initCountUps("[data-count]");
  initComets(".space-el");
  // Ambient colour flow anchored to the real section positions, so each
  // section shows its own hue: hero blue/cyan, disciplines violet/amber,
  // work amber, about blue, writing emerald, film red, contact brand blue.
  initAmbient(
    [
      ["91,141,239", "34,211,238"],
      ["167,139,250", "245,165,36"],
      ["245,165,36", "245,165,36"],
      ["91,141,239", "91,141,239"],
      ["52,211,153", "91,141,239"],
      ["244,63,94", "244,63,94"],
      ["0,102,204", "34,211,238"],
    ],
    ["home", "disciplines", "work", "about", "writing", "filmmaking", "contact"],
  );

  // Progress rail: highlight the dot for the section in view.
  (function () {
    const links = new Map<string, HTMLElement>();
    document
      .querySelectorAll<HTMLElement>(".rail a[data-rail]")
      .forEach((a) => links.set(a.dataset.rail || "", a));
    if (!links.size || !("IntersectionObserver" in window)) return;
    const io = new IntersectionObserver(
      (entries) => {
        for (const en of entries) {
          if (!en.isIntersecting) continue;
          links.forEach((a) => a.classList.remove("on"));
          links.get(en.target.id)?.classList.add("on");
        }
      },
      { threshold: 0.35 },
    );
    links.forEach((_, id) => {
      const s = document.getElementById(id);
      if (s) io.observe(s);
    });
  })();
</script>
