---
import BaseLayout from "../layouts/BaseLayout.astro";
import { info } from "../data/info";
import { disciplines } from "../data/disciplines";
import Contact from "../components/contact_section/Contact";
import Picture from "../components/common/Picture.astro";
import Icon from "../components/common/Icon.astro";
import GlassHero from "../components/hero/GlassHero.astro";
import { readingTime } from "../utils/readingTime";

const allPosts = await Astro.glob("../pages/posts/*.md");
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).getTime() -
      new Date(a.frontmatter.date).getTime(),
  )
  .slice(0, 4);
const [featuredPost, ...sidePosts] = latestPosts;

// The six flagship Hybridge systems. Metrics that are plain numbers carry
// count-up data attributes; textual metrics render as-is.
const systems = [
  {
    n: "01",
    name: "Enterprise Search",
    tagline: "The whole company's knowledge, answered with citations or an honest no.",
    metric: "cite or abstain",
    metricLabel: "a RAG that refuses to bluff",
    accent: "#34D399",
    href: "/posts/enterprise-search",
  },
  {
    n: "02",
    name: "Consultation QA",
    tagline: "Every patient consult scored from its Zoom call, turned into coaching.",
    metric: "+130%",
    count: { value: 130, prefix: "+", suffix: "%" },
    metricLabel: "treatment acceptance",
    accent: "#22D3EE",
    href: "/posts/clinical-rag",
  },
  {
    n: "03",
    name: "CBCT Scan Validator",
    tagline: "Bad dental CT scans caught before they reach the design queue.",
    metric: "$50/mo",
    count: { value: 50, prefix: "$", suffix: "/mo" },
    metricLabel: "vs the $124K year-one quote",
    accent: "#A78BFA",
    href: "/posts/cbct-scan-validator",
  },
  {
    n: "04",
    name: "NPC Coach",
    tagline: "Finds the new-patient calls among thousands, then coaches them.",
    metric: "285 → 40",
    metricLabel: "calls ingested, then scored, day one",
    accent: "#5B8DEF",
    href: "/posts/npc-coach",
  },
  {
    n: "05",
    name: "Treatment Estimator",
    tagline: "Live quoting with a price promise the database itself enforces.",
    metric: "1 month",
    metricLabel: "vs the decade-long vendor attempt",
    accent: "#F5A524",
    href: "/posts/treatment-estimator",
  },
  {
    n: "06",
    name: "Diagnostic Filter",
    tagline: "AI assesses the patient first. The doctor still signs every finding.",
    metric: "0 → 200",
    metricLabel: "tooth-loss risk, scored pre-consult",
    accent: "#F43F5E",
    href: "/posts/cdf-diagnostic-filter",
  },
];

// One-line versions of the four disciplines for the tiles.
const disciplineLines: Record<string, string> = {
  aie: "RAG, agents, evals, guardrails. Systems that answer honestly or not at all.",
  mle: "PyTorch, vision, RLHF. Models trained, shrunk, and shipped to real hardware.",
  fde: "Discovery and enablement, the last mile where software meets people.",
  sde: "Python, TypeScript, Go. APIs, pipelines, and infra that stay up.",
};

const filmCredits = [
  { title: "Among Monsters", year: "2026", role: "Director · Writer · Editor · Music" },
  { title: "Extraordinary Lives", year: "soon", role: "Director · Writer" },
  { title: "Tiger Man", year: "2022", role: "Director · Writer · Editor" },
  { title: "Strangers", year: "2019", role: "Cinematographer · Music" },
];

// Institution logos for the Education/Experience rows. Falls back to a
// gradient monogram for anywhere without a logo file.
const orgFor = (loc: string) => {
  if (/Hybridge/i.test(loc)) return { logo: "/logos/hybridge.webp", label: "Hybridge Implants" };
  if (/Shure/i.test(loc)) return { logo: "/logos/shure.svg", label: "Shure" };
  if (/JNTU|Jawaharlal Nehru|Gokaraju/i.test(loc)) return { logo: "/logos/griet.png", label: "Gokaraju Rangaraju Institute of Engineering and Technology" };
  if (/New York University|NYU/i.test(loc)) return { logo: "/logos/nyu.svg", label: "New York University" };
  return { logo: null, acronym: loc.slice(0, 2).toUpperCase(), label: loc };
};

// Toolkit marquee, replacing the four skill tile walls.
const marqueeItems = [
  { name: "Python", accent: "#5B8DEF" },
  { name: "PyTorch", accent: "#A78BFA" },
  { name: "RAG", accent: "#34D399" },
  { name: "Vertex Gemini", accent: "#34D399" },
  { name: "FastAPI", accent: "#5B8DEF" },
  { name: "BigQuery", accent: "#F5A524" },
  { name: "TypeScript", accent: "#5B8DEF" },
  { name: "Hugging Face", accent: "#A78BFA" },
  { name: "pgvector", accent: "#34D399" },
  { name: "Terraform", accent: "#5B8DEF" },
  { name: "Evals", accent: "#34D399" },
  { name: "React", accent: "#5B8DEF" },
  { name: "RLHF", accent: "#A78BFA" },
  { name: "Docker", accent: "#5B8DEF" },
  { name: "Looker", accent: "#F5A524" },
  { name: "Guardrails", accent: "#34D399" },
  { name: "PostgreSQL", accent: "#5B8DEF" },
  { name: "OpenCV", accent: "#A78BFA" },
];

const sections = [
  { id: "home", label: "Top" },
  { id: "disciplines", label: "Disciplines" },
  { id: "work", label: "Work" },
  { id: "about", label: "About" },
  { id: "writing", label: "Writing" },
  { id: "filmmaking", label: "Film" },
  { id: "contact", label: "Contact" },
];
---

<BaseLayout title="Sampreeth Avvari" preloadImage="/pic.avif">
  <nav class="rail" aria-label="Page sections">
    {sections.map((s) => (
      <a href={`#${s.id}`} data-rail={s.id} aria-label={s.label}></a>
    ))}
  </nav>

  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section id="home" class="relative min-h-[100svh] flex items-center overflow-hidden pt-24 pb-16">
    <GlassHero />
    <span class="glow" style="width:630px;height:630px;--gc:#5B8DEF;top:-90px;left:-120px;" aria-hidden="true"></span>
    <span class="glow glow-2" style="width:540px;height:540px;--gc:#22D3EE;bottom:-80px;right:-70px;" aria-hidden="true"></span>
    <span class="space-el" style="width:143px;height:39px;top:14%;left:5%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:91,141,239;"></span><span class="space-comet" style="--sr-rgb:91,141,239;--rz:-16deg;"></span></span>
    <span class="space-el" style="width:117px;height:33px;bottom:18%;right:7%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:34,211,238;"></span><span class="space-comet" style="--sr-rgb:34,211,238;--rz:12deg;"></span></span>

    <div class="relative z-10 mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <div class="lg:col-span-7" data-arrive>
          <p class="eyebrow text-text/60 dark:text-dk-text/60 mb-5">
            AI Engineer · New York
          </p>
          <h1 class="text-[2.6rem] leading-[1.04] sm:text-6xl lg:text-7xl font-bold tracking-[-0.04em] text-text dark:text-dk-text [text-wrap:balance]">
            I'm <span class="name-shimmer">Sampreeth</span>.<br />
            I ship AI and direct films.
          </h1>
          <p class="mt-6 text-lg lg:text-xl text-text/70 dark:text-dk-text/70 leading-relaxed max-w-xl">
            Whether it's a model or a movie, the job is making the messy thing make sense to someone else.
          </p>
          <div class="mt-7 flex flex-wrap gap-2" aria-label="Disciplines">
            {disciplines.map((d) => (
              <a
                href={`/work/${d.slug}`}
                class="no-lift dpill"
                data-magnetic
                style={`--dx: ${d.accent}; --dx-rgb: ${d.rgb};`}
                aria-label={d.name}
              >
                <i aria-hidden="true"></i>
                <span>{d.acronym}</span>
              </a>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#work" class="no-lift gbtn" data-magnetic>
              See the work <Icon name="arrow-down" size={15} />
            </a>
            <a href="/posts" class="no-lift gbtn-ghost" data-magnetic>
              Read the writing
            </a>
          </div>
        </div>

        <div class="lg:col-span-5 flex justify-center lg:justify-end" data-arrive>
          <figure class="pane pane-glare p-3 w-[min(320px,78vw)]" data-tilt data-tiltmax="5">
            <Picture
              src={info.picture}
              alt={info.picture_alt}
              width={520}
              height={640}
              class="block w-full h-auto aspect-[520/640] object-cover rounded-2xl"
              loading="eager"
              fetchpriority="high"
            />
            <figcaption class="sr-only">{info.name}</figcaption>
          </figure>
        </div>
      </div>
    </div>

    <a class="scroll-cue no-lift" href="#disciplines" aria-label="Scroll to disciplines">
      <Icon name="arrow-down" size={20} />
    </a>
  </section>

  <!-- ── Toolkit marquee ──────────────────────────────────────────────── -->
  <div class="mq" aria-hidden="true">
    <div class="mq-track">
      {[0, 1].map(() =>
        marqueeItems.map((it) => (
          <span style={`--mc: ${it.accent}`}>
            <b>{it.name}</b> ·
          </span>
        )),
      )}
    </div>
  </div>

  <!-- ── Disciplines ──────────────────────────────────────────────────── -->
  <section id="disciplines" class="relative overflow-hidden py-24 lg:py-32">
    <span class="glow" style="width:600px;height:600px;--gc:#A78BFA;top:6%;right:-120px;" aria-hidden="true"></span>
    <span class="glow glow-3" style="width:510px;height:510px;--gc:#F5A524;bottom:-70px;left:-90px;" aria-hidden="true"></span>
    <span class="space-el" style="width:150px;height:39px;top:8%;right:5%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:167,139,250;"></span><span class="space-comet" style="--sr-rgb:167,139,250;--rz:-18deg;"></span></span>
    <span class="space-el" style="width:117px;height:33px;bottom:12%;left:4%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:167,139,250;"></span><span class="space-comet" style="--sr-rgb:167,139,250;--rz:10deg;"></span></span>
    <div class="relative z-[1] mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
      <div class="max-w-3xl" data-arrive>
        <p class="eyebrow text-acc-violet mb-3">01 · What I do</p>
        <h2 class="display-sm text-text dark:text-dk-text mb-4">
          One engineer, <span class="text-acc-violet">four disciplines</span>.
        </h2>
        <p class="text-base lg:text-lg text-text/65 dark:text-dk-text/65 leading-relaxed max-w-2xl">
          The same instinct runs through all four: sit next to the person with the problem, then build the thing they actually needed.
        </p>
      </div>
      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4" data-arrive>
        {disciplines.map((d) => (
          <a
            href={`/work/${d.slug}`}
            class="no-lift pane pane-glare orbit-glow overflow-hidden p-6 flex flex-col gap-2 group"
            data-tilt
            data-tiltmax="4"
            style={`--oc: ${d.accent};`}
          >
            <span
              class="font-mono text-[0.7rem] font-extrabold tracking-[0.2em]"
              style={`color: ${d.accent};`}
            >
              {d.acronym}
            </span>
            <h3 class="text-lg font-semibold tracking-tight text-text dark:text-dk-text">
              {d.name}
            </h3>
            <p class="relative z-[1] text-sm text-text/60 dark:text-dk-text/60 leading-snug">
              {disciplineLines[d.slug]}
            </p>
            <span class="mt-auto pt-3 text-[0.78rem] font-bold inline-flex items-center gap-1.5" style={`color: ${d.accent};`}>
              {d.projects.length} project{d.projects.length === 1 ? "" : "s"}
              <Icon name="arrow-right" size={13} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Work ─────────────────────────────────────────────────────────── -->
  <section id="work" class="relative overflow-hidden py-24 lg:py-32">
    <span class="glow" style="width:660px;height:660px;--gc:#F5A524;top:-110px;left:28%;" aria-hidden="true"></span>
    <span class="glow glow-2" style="width:510px;height:510px;--gc:#F5A524;bottom:-90px;right:-70px;" aria-hidden="true"></span>
    <span class="space-el" style="width:156px;height:39px;top:7%;right:5%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:245,165,36;"></span><span class="space-comet" style="--sr-rgb:245,165,36;--rz:-14deg;"></span></span>
    <span class="space-el" style="width:117px;height:33px;bottom:9%;left:4%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:245,165,36;"></span><span class="space-comet" style="--sr-rgb:245,165,36;--rz:12deg;"></span></span>
    <div class="relative z-[1] mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
      <div class="max-w-3xl" data-arrive>
        <p class="eyebrow text-acc-amber mb-3">02 · The work</p>
        <h2 class="display-sm text-text dark:text-dk-text mb-4">
          Six systems, inside a <span class="text-acc-amber">dental practice</span>.
        </h2>
        <p class="text-base lg:text-lg text-text/65 dark:text-dk-text/65 leading-relaxed max-w-2xl">
          Real AI built next to the people who use it every day. The ones worth showing survived real people using them.
        </p>
      </div>

      <ul class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0 m-0" data-arrive>
        {systems.map((s) => (
          <li class="h-full">
            <a
              href={s.href}
              class="no-lift pane pane-glare h-full p-6 flex flex-col gap-2 group"
              data-tilt
              data-tiltmax="4"
            >
              <span class="font-mono text-[0.68rem] font-bold tabular-nums text-text/35 dark:text-dk-text/35">
                {s.n}
              </span>
              <span
                class="metric text-2xl lg:text-[1.7rem] font-bold tabular-nums tracking-tight leading-none"
                style={`color: ${s.accent};`}
                {...(s.count
                  ? {
                      "data-count": s.count.value,
                      "data-prefix": s.count.prefix,
                      "data-suffix": s.count.suffix,
                    }
                  : {})}
              >
                {s.metric}
              </span>
              <h3 class="text-lg font-semibold tracking-tight text-text dark:text-dk-text group-hover:text-secondary dark:group-hover:text-dk-secondary transition">
                {s.name}
              </h3>
              <p class="text-sm text-text/60 dark:text-dk-text/60 leading-snug">
                {s.tagline}
              </p>
              <span class="mt-auto pt-3 text-[0.62rem] uppercase tracking-[0.16em] font-semibold text-text/40 dark:text-dk-text/40">
                {s.metricLabel}
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-9" data-arrive>
        <a href="/projects" class="link-underline text-sm font-semibold text-acc-amber inline-flex items-center gap-1.5">
          Browse all 15 projects <Icon name="arrow-right" size={14} />
        </a>
      </div>
    </div>
  </section>

  <!-- ── About ────────────────────────────────────────────────────────── -->
  <section id="about" class="relative overflow-hidden py-24 lg:py-32">
    <span class="glow" style="width:570px;height:570px;--gc:#5B8DEF;top:8%;left:-110px;" aria-hidden="true"></span>
    <span class="glow glow-3" style="width:450px;height:450px;--gc:#5B8DEF;bottom:-80px;right:-60px;" aria-hidden="true"></span>
    <span class="space-el" style="width:137px;height:36px;top:8%;right:7%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:91,141,239;"></span><span class="space-comet" style="--sr-rgb:91,141,239;--rz:-12deg;"></span></span>
    <div class="relative z-[1] mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start" data-arrive>
        <div class="lg:col-span-5">
          <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">03 · About</p>
          <h2 class="display-sm text-text dark:text-dk-text mb-5">
            An engineer who happens to <span class="text-secondary dark:text-dk-secondary">make movies</span>.
          </h2>
          <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed">
            {info.about.description}
          </p>
          <div class="mt-7 flex flex-wrap gap-x-6 gap-y-2">
            <a href="/projects" class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary inline-flex items-center gap-1.5">
              See all the projects <Icon name="arrow-right" size={14} />
            </a>
            <a href="/resume" class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary inline-flex items-center gap-1.5">
              Full toolkit on the resume <Icon name="arrow-right" size={14} />
            </a>
          </div>
        </div>

        <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-9">
          <div id="education">
            <p class="eyebrow text-secondary/80 dark:text-dk-secondary/80 mb-5">Education</p>
            <ul class="space-y-5 list-none p-0 m-0">
              {info.about.education.map((ed) => {
                const b = orgFor(ed.location);
                return (
                  <li class="timeline-row text-sm">
                    {b.logo ? (
                      <div class="org-badge">
                        <img src={b.logo} alt={b.label} loading="lazy" />
                      </div>
                    ) : (
                      <div class="org-badge org-badge-mono" aria-label={b.label}>
                        <span>{b.acronym}</span>
                      </div>
                    )}
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-text dark:text-dk-text leading-snug">{ed.title}</p>
                      <p class="text-text/60 dark:text-dk-text/60 leading-snug">{ed.location}</p>
                      <p class="text-text/40 dark:text-dk-text/40 text-xs mt-1">
                        {ed.date}{ed.gpa ? ` · GPA ${ed.gpa}` : ""}
                      </p>
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>
          <div id="experience">
            <p class="eyebrow text-acc-amber/90 mb-5">Experience</p>
            <ul class="space-y-5 list-none p-0 m-0">
              {info.about.experience.map((ex) => {
                const b = orgFor(ex.location);
                return (
                  <li class="timeline-row text-sm">
                    {b.logo ? (
                      <div class="org-badge">
                        <img src={b.logo} alt={b.label} loading="lazy" />
                      </div>
                    ) : (
                      <div class="org-badge org-badge-mono" aria-label={b.label}>
                        <span>{b.acronym}</span>
                      </div>
                    )}
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-text dark:text-dk-text leading-snug">{ex.title}</p>
                      <p class="text-text/60 dark:text-dk-text/60 leading-snug">{ex.location}</p>
                      <p class="text-text/40 dark:text-dk-text/40 text-xs mt-1">{ex.date}</p>
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Writing ──────────────────────────────────────────────────────── -->
  <section id="writing" class="relative overflow-hidden py-24 lg:py-32">
    <span class="glow" style="width:570px;height:570px;--gc:#34D399;top:14%;left:-100px;" aria-hidden="true"></span>
    <span class="glow glow-3" style="width:480px;height:480px;--gc:#34D399;bottom:-70px;right:8%;" aria-hidden="true"></span>
    <span class="space-el" style="width:143px;height:38px;top:10%;right:6%;" aria-hidden="true"><span class="comet-glow" style="--sr-rgb:52,211,153;"></span><span class="space-comet" style="--sr-rgb:52,211,153;--rz:-16deg;"></span></span>
    <div class="relative z-[1] mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
      <div class="flex items-end justify-between gap-6 mb-10" data-arrive>
        <div>
          <p class="eyebrow text-acc-emerald mb-3">04 · Writing</p>
          <h2 class="display-sm text-text dark:text-dk-text mb-3">
            Notes from <span class="text-acc-emerald">the work</span>.
          </h2>
          <p class="text-base lg:text-lg text-text/65 dark:text-dk-text/65 leading-relaxed max-w-2xl">
            Real numbers, real screwups, real fixes.
          </p>
        </div>
        <a href="/posts" class="link-underline text-sm font-semibold text-acc-emerald hidden lg:inline-flex items-center gap-1.5 shrink-0">
          All posts <Icon name="arrow-right" size={14} />
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-4" data-arrive>
        {featuredPost && (
          <a
            href={featuredPost.url}
            class="no-lift pane pane-glare pane-rim overflow-hidden lg:col-span-3 flex flex-col group"
            data-tilt
            data-tiltmax="2"
          >
            {featuredPost.frontmatter.img_path && (
              <div class="relative overflow-hidden rounded-t-[24px]">
                <Picture
                  src={featuredPost.frontmatter.img_path}
                  alt={featuredPost.frontmatter.img_alt || featuredPost.frontmatter.title}
                  width={900}
                  height={480}
                  class="w-full h-56 lg:h-72 object-cover transition duration-500 group-hover:scale-[1.03]"
                />
                <span class="absolute top-3 right-3 featured-badge text-[0.62rem]">Latest</span>
              </div>
            )}
            <div class="p-6 lg:p-7 flex flex-col gap-3 flex-1">
              <p class="text-[0.66rem] uppercase tracking-[0.18em] font-semibold text-text/40 dark:text-dk-text/40 tabular-nums inline-flex items-center gap-2">
                {featuredPost.frontmatter.date}
                <span aria-hidden="true">·</span>
                <span class="inline-flex items-center gap-1"><Icon name="clock" size={12} /> {readingTime(featuredPost.rawContent())} min</span>
              </p>
              <h3 class="text-xl lg:text-3xl font-bold tracking-tight text-text dark:text-dk-text leading-[1.12] group-hover:text-secondary dark:group-hover:text-dk-secondary transition">
                {featuredPost.frontmatter.title}
              </h3>
              <p class="text-sm lg:text-base text-text/60 dark:text-dk-text/60 leading-relaxed line-clamp-2">
                {featuredPost.frontmatter.description}
              </p>
            </div>
          </a>
        )}
        <div class="lg:col-span-2 grid grid-cols-1 gap-4">
          {sidePosts.map((post) => (
            <a
              href={post.url}
              class="no-lift pane pane-glare overflow-hidden flex items-stretch group"
              data-tilt
              data-tiltmax="3"
            >
              {post.frontmatter.img_path && (
                <div class="w-32 shrink-0 overflow-hidden">
                  <Picture
                    src={post.frontmatter.img_path}
                    alt={post.frontmatter.img_alt || post.frontmatter.title}
                    width={300}
                    height={220}
                    class="w-full h-full object-cover transition duration-500 group-hover:scale-[1.05]"
                  />
                </div>
