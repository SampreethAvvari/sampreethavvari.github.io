---
import BaseLayout from "../layouts/BaseLayout.astro";
import { info } from "../data/info";
import Contact from "../components/contact_section/Contact";
import ScrollSpine from "../components/ScrollSpine.astro";
import DisciplineGrid from "../components/work_section/DisciplineGrid.astro";
import { disciplines } from "../data/disciplines";
import { Image } from "astro:assets";

const allPosts = await Astro.glob("../pages/posts/*.md");
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).getTime() -
      new Date(a.frontmatter.date).getTime(),
  )
  .slice(0, 4);

// The six flagship Hybridge systems, in display order on the home strip.
const systems = [
  {
    n: "01",
    name: "Enterprise Search (RAG)",
    tagline:
      "Ask the whole company's knowledge in plain language, and get a cited answer or an honest \"I don't know.\"",
    metric: "cite or abstain",
    metricLabel: "a RAG that refuses to bluff",
    accent: "#34D399",
    href: "/posts/enterprise-search",
  },
  {
    n: "02",
    name: "Consultation QA Pipeline",
    tagline:
      "Scores every patient consult from its Zoom call and turns it into instant coaching.",
    metric: "+130%",
    metricLabel: "treatment acceptance",
    accent: "#22D3EE",
    href: "/posts/clinical-rag",
  },
  {
    n: "03",
    name: "CBCT Scan Validator",
    tagline:
      "Catches bad dental CT scans before they reach the design queue.",
    metric: "$50/mo",
    metricLabel: "vs the $124K year-one quote",
    accent: "#A78BFA",
    href: "/posts/cbct-scan-validator",
  },
  {
    n: "04",
    name: "NPC Coach",
    tagline:
      "Finds the new-patient calls among thousands and coaches them, with a transcript quote behind every score.",
    metric: "285 to 40",
    metricLabel: "calls ingested, then scored, day one",
    accent: "#5B8DEF",
    href: "/posts/npc-coach",
  },
  {
    n: "05",
    name: "Treatment Estimator",
    tagline:
      "Live quoting for coordinators, with the price promise the database itself enforces.",
    metric: "1 month",
    metricLabel: "vs the decade-long vendor attempt that never shipped",
    accent: "#F5A524",
    href: "/posts/treatment-estimator",
  },
  {
    n: "06",
    name: "Centralized Diagnostic Filter",
    tagline:
      "AI assesses the patient before the doctor walks in, and the doctor still signs every finding.",
    metric: "0 to 200",
    metricLabel: "tooth-loss risk, scored before the consult",
    accent: "#FB7185",
    href: "/posts/cdf-diagnostic-filter",
  },
];

const filmCredits = [
  { title: "Among Monsters", year: "2026", role: "Director · Writer · Editor · Music" },
  { title: "Extraordinary Lives", year: "upcoming", role: "Director · Writer" },
  { title: "Tiger Man", year: "2022", role: "Director · Writer · Editor" },
  { title: "Strangers", year: "2019", role: "Cinematographer · Music" },
];

// Brand monograms for the Education/Experience timeline rows. Same colour
// language across all four so Shure is as readable as NYU.
const brandFor = (loc: string) => {
  if (/Hybridge/i.test(loc)) return { acronym: "HB", from: "#1E3A8A", to: "#3B82F6", label: "Hybridge" };
  if (/Shure/i.test(loc))    return { acronym: "SH", from: "#047857", to: "#10B981", label: "Shure" };
  if (/JNTU|Jawaharlal Nehru/i.test(loc)) return { acronym: "JNTU", from: "#991B1B", to: "#EF4444", label: "JNTU" };
  if (/New York University|NYU/i.test(loc)) return { acronym: "NYU", from: "#57068C", to: "#9333EA", label: "NYU" };
  return { acronym: loc.slice(0, 2).toUpperCase(), from: "#475569", to: "#94A3B8", label: loc };
};

// Skills organized into the four disciplines (AIE, MLE, FDE, SDE), matching
// the disciplines section's colours. Every skill is a labelled tile: an
// official logo (self-hosted SVG) or a FontAwesome icon for things with no
// brand mark, plus the name and a hover tooltip with the project count.
// Curated to the meaningful, role-relevant tools. `projects` is the number of
// these projects that used it (minimum 1).
const skillGroups = [
  {
    label: "AI Engineering",
    acronym: "AIE",
    accent: "#34D399",
    rgb: "52, 211, 153",
    items: [
      { name: "Vertex Gemini", file: "googlegemini", projects: 5 },
      { name: "Hugging Face", file: "huggingface", projects: 3 },
      { name: "LangChain", file: "langchain", projects: 1 },
      { name: "OpenAI", icon: "fa-solid fa-robot", projects: 1 },
      { name: "Anthropic", file: "anthropic", projects: 1 },
      { name: "Pydantic", file: "pydantic", projects: 4 },
      { name: "RAG", icon: "fa-solid fa-magnifying-glass", projects: 2 },
      { name: "pgvector", icon: "fa-solid fa-diagram-project", projects: 2 },
      { name: "Reranking", icon: "fa-solid fa-arrow-down-wide-short", projects: 1 },
      { name: "Structured output", icon: "fa-solid fa-code", projects: 4 },
      { name: "Evals", icon: "fa-solid fa-clipboard-check", projects: 2 },
      { name: "Guardrails", icon: "fa-solid fa-shield-halved", projects: 1 },
    ],
  },
  {
    label: "Machine Learning",
    acronym: "MLE",
    accent: "#A78BFA",
    rgb: "167, 139, 250",
    items: [
      { name: "PyTorch", file: "pytorch", projects: 4 },
      { name: "scikit-learn", file: "scikitlearn", projects: 2 },
      { name: "NumPy", file: "numpy", projects: 4 },
      { name: "OpenCV", file: "opencv", projects: 2 },
      { name: "ONNX", file: "onnx", projects: 1 },
      { name: "W&B", file: "wandb", projects: 2 },
      { name: "MLflow", file: "mlflow", projects: 1 },
      { name: "MONAI", icon: "fa-solid fa-staff-snake", projects: 1 },
      { name: "nnU-Net", icon: "fa-solid fa-diagram-project", projects: 1 },
      { name: "OpenVINO", icon: "fa-solid fa-microchip", projects: 1 },
      { name: "TRL", icon: "fa-solid fa-dumbbell", projects: 2 },
      { name: "RLHF", icon: "fa-solid fa-thumbs-up", projects: 1 },
    ],
  },
  {
    label: "Forward-Deployed",
    acronym: "FDE",
    accent: "#F5A524",
    rgb: "245, 165, 36",
    items: [
      { name: "Google Cloud", file: "googlecloud", projects: 8 },
      { name: "BigQuery", file: "googlebigquery", projects: 3 },
      { name: "Gmail API", file: "gmail", projects: 3 },
      { name: "Sheets API", file: "googlesheets", projects: 2 },
      { name: "Looker", file: "looker", projects: 1 },
      { name: "Zoom", file: "zoom", projects: 2 },
      { name: "Figma", file: "figma", projects: 2 },
      { name: "Apps Script", icon: "fa-solid fa-file-code", projects: 2 },
      { name: "Monday.com", icon: "fa-solid fa-table-columns", projects: 2 },
      { name: "Slack", icon: "fa-brands fa-slack", projects: 1 },
      { name: "Discovery", icon: "fa-solid fa-compass", projects: 9 },
      { name: "Enablement", icon: "fa-solid fa-chalkboard-user", projects: 1 },
    ],
  },
  {
    label: "Software Engineering",
    acronym: "SDE",
    accent: "#5B8DEF",
    rgb: "91, 141, 239",
    items: [
      { name: "Python", file: "python", projects: 9 },
      { name: "TypeScript", file: "typescript", projects: 4 },
      { name: "Go", file: "go", projects: 2 },
      { name: "React", file: "react", projects: 3 },
      { name: "Next.js", file: "nextdotjs", projects: 2 },
      { name: "FastAPI", file: "fastapi", projects: 7 },
      { name: "PostgreSQL", file: "postgresql", projects: 3 },
      { name: "Docker", file: "docker", projects: 4 },
      { name: "Kubernetes", file: "kubernetes", projects: 1 },
      { name: "Terraform", file: "terraform", projects: 3 },
      { name: "GitHub Actions", file: "githubactions", projects: 4 },
      { name: "pytest", file: "pytest", projects: 4 },
      { name: "Redis", file: "redis", projects: 2 },
      { name: "Node.js", file: "nodedotjs", projects: 2 },
    ],
  },
];
---

<BaseLayout title="Sampreeth Avvari">
  <script is:inline>
    document.documentElement.classList.add("snap-home");
  </script>
  <div class="snap-chapters relative">
    <ScrollSpine />

    <!-- ── Chapter 1: Hero ───────────────────────────────────────────────── -->
    <section
      class="chapter chapter-full snap-chapter relative landing-atmos overflow-hidden"
      id="home"
    >
      <!-- Full-bleed aurora background: an animated four-discipline colour
           field always, a generated dark-mode Veo clip, the generated aurora
           still, parallax glow orbs, and a readability scrim. The portrait
           that used to sit here now floats in the About chapter. -->
      <div class="hero-bg" aria-hidden="true">
        <img class="hero-nebula hero-nebula-dark" src="/hero-nebula-dark.png" alt="" data-parallax="0.012" />
        <img class="hero-nebula hero-nebula-light" src="/hero-nebula-light.png" alt="" data-parallax="0.012" />
        <img class="hero-aurora hero-aurora-dark" src="/hero-aurora-dark.png" alt="" data-parallax="0.026" />
        <img class="hero-aurora hero-aurora-light" src="/hero-aurora-light.png" alt="" data-parallax="0.026" />
        <div class="hero-field"></div>
        <span class="hero-orb hero-orb-emerald" data-parallax="0.06"></span>
        <span class="hero-orb hero-orb-amber" data-parallax="0.07"></span>
        <canvas class="hero-canvas" data-hero-canvas></canvas>
        <div class="hero-grain"></div>
        <div class="hero-scrim"></div>
      </div>

      <div class="relative z-10 pointer-events-none mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="grid grid-cols-[1.55fr_1fr] lg:grid-cols-12 items-start lg:items-center gap-4 lg:gap-8">
          <div class="hero-copy lg:col-span-7 flex flex-col items-start gap-4 lg:gap-6 text-left">
            <p class="eyebrow text-text/60 dark:text-dk-text/60">
              AI Engineer · New York
            </p>
            <h1 class="hero-title text-text dark:text-dk-text glow-wave">
              <span class="hero-line">I'm <span class="text-secondary dark:text-dk-secondary text-shimmer">Sampreeth.</span></span>
              <span class="hero-line">I ship AI and direct films.</span>
            </h1>
            <p class="hero-lead text-xl lg:text-2xl text-text/75 dark:text-dk-text/75 leading-relaxed glow-wave glow-delay-2 max-w-xl">
              Whether it's a model or a movie, the job is making the messy thing make sense to someone else.
            </p>
            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2.5 pt-1" aria-label="Disciplines">
              {disciplines.map((d) => (
                <a
                  href={`/work/${d.slug}`}
                  class="dx-pill no-lift"
                  style={`--dx: ${d.accent}; --dx-rgb: ${d.rgb};`}
                  title={d.name}
                  aria-label={d.name}
                >
                  <span class="dx-pill-dot" aria-hidden="true"></span>
                  <span>{d.acronym}</span>
                </a>
              ))}
            </div>
            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 pt-3">
              <a href="#disciplines" class="hero-btn hero-btn-primary no-lift">
                See the work <span aria-hidden="true">↓</span>
              </a>
              <a href="/posts" class="hero-btn hero-btn-ghost no-lift">
                Read the writing
              </a>
              <a href="#contact" class="hero-btn hero-btn-ghost no-lift">
                Get in touch
              </a>
            </div>
          </div>

          <div class="lg:col-span-5 flex justify-end items-start lg:items-center">
            <figure class="hero-portrait floaty">
              <span class="hero-portrait-glow" aria-hidden="true"></span>
              <div class="hero-portrait-frame photo-shimmer">
                <Image
                  src={info.picture}
                  alt={info.picture_alt}
                  width={520}
                  height={640}
                  class="hero-portrait-img"
                />
              </div>
            </figure>
          </div>
        </div>
      </div>

      <a
        href="#disciplines"
        aria-label="Scroll"
        class="no-lift absolute bottom-8 left-1/2 -translate-x-1/2 text-text/40 dark:text-dk-text/40 hover:text-text dark:hover:text-dk-text transition animate-pulse"
      >
        <i class="fas fa-chevron-down text-xl"></i>
      </a>
    </section>

    <!-- ── Chapter 2: What I do (four disciplines) ───────────────────────── -->
    <DisciplineGrid />

    <!-- ── Chapter 3: The work ───────────────────────────────────────────── -->
    <section class="chapter snap-chapter chapter-fade" id="work">
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="max-w-4xl reveal" data-reveal>
          <p class="eyebrow text-secondary dark:text-dk-secondary mb-3" data-spine-dot>
            02 / The work
          </p>
          <h2 class="display-sm text-text dark:text-dk-text mb-3 glow-wave" data-spine-heading>
            Six systems, inside a dental practice.
          </h2>
          <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed max-w-2xl">
            Real AI I built next to the people who use it every day. The
            coordinator, the controller, the CEO. The ones I'm proudest of
            are the ones that survived real people using them.
          </p>
        </div>

        <ul class="mt-8 lg:mt-12 divide-y divide-text/10 dark:divide-dk-text/10 reveal" data-reveal>
          {systems.map((s) => (
            <li>
              <a
                href={s.href}
                class="no-lift group flex flex-col lg:flex-row lg:items-center gap-3 lg:gap-8 py-4 lg:py-5 transition"
              >
                {/* On mobile: number + title share one line via flex items-baseline.
                    At lg: lg:contents dissolves this wrapper so both children
                    participate directly in the parent flex row, preserving
                    [number(w-10)] [flex-1 div] [metric(min-w-9rem)] [arrow] layout. */}
                <div class="flex items-baseline gap-3 lg:contents">
                  <span
                    class="font-mono text-sm font-semibold tabular-nums w-10 shrink-0 text-text/40 dark:text-dk-text/40"
                  >
                    {s.n}
                  </span>
                  <div class="flex-1 min-w-0">
                    <h3
                      class="text-xl lg:text-2xl font-semibold tracking-tight text-text dark:text-dk-text group-hover:text-secondary dark:group-hover:text-dk-secondary transition"
                    >
                      {s.name}
                    </h3>
                    <p class="mt-0.5 text-sm text-text/65 dark:text-dk-text/65 leading-snug max-w-3xl line-clamp-2">
                      {s.tagline}
                    </p>
                  </div>
                </div>
                <div class="lg:text-right lg:min-w-[9rem] shrink-0">
                  <div
                    class="text-xl lg:text-2xl font-semibold tabular-nums tracking-tight"
                    style={`color: ${s.accent};`}
                  >
                    {s.metric}
                  </div>
                  <div class="text-[0.65rem] uppercase tracking-[0.18em] text-text/45 dark:text-dk-text/45 mt-0.5">
                    {s.metricLabel}
                  </div>
                </div>
                <span
                  class="hidden lg:inline text-text/40 dark:text-dk-text/40 group-hover:text-secondary dark:group-hover:text-dk-secondary group-hover:translate-x-1 lg:transition-transform"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-10 flex items-center justify-between flex-wrap gap-4">
          <a
            href="/projects"
            class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary"
          >
            Browse all 15 projects <span aria-hidden="true">→</span>
          </a>
          <p class="text-xs text-text/40 dark:text-dk-text/40">
            Scroll for the rest of the story
          </p>
        </div>
      </div>
    </section>

    <!-- ── Chapter 3: About ──────────────────────────────────────────────── -->
    <section class="chapter snap-chapter chapter-fade" id="about">
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <!-- Intro left, education + experience right, so the row reads full. -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start reveal" data-reveal>
          <div class="lg:col-span-5">
            <p class="eyebrow text-secondary dark:text-dk-secondary mb-5" data-spine-dot>
              03 / About
            </p>
            <h2 class="display-sm text-text dark:text-dk-text mb-6 glow-wave" data-spine-heading>
              An engineer who happens to <span class="text-secondary dark:text-dk-secondary">make movies</span>.
            </h2>
            <p class="text-base lg:text-lg text-text/75 dark:text-dk-text/75 leading-relaxed">
              {info.about.description}
            </p>
            <a
              href="/projects"
              class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary mt-7 inline-flex"
            >
              See all the projects <span aria-hidden="true">→</span>
            </a>
          </div>

          <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-9">
            <div id="education">
              <p class="eyebrow text-secondary/80 dark:text-dk-secondary/80 mb-5">
                Education
              </p>
              <ul class="space-y-5">
                {info.about.education.map((ed) => {
                  const b = brandFor(ed.location);
                  return (
                    <li class="timeline-row text-sm">
                      <div
                        class="brand-badge"
                        style={`background: linear-gradient(135deg, ${b.from}, ${b.to});`}
                        aria-label={b.label}
                      >
                        <span>{b.acronym}</span>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="font-semibold text-text dark:text-dk-text leading-snug">
                          {ed.title}
                        </p>
                        <p class="text-text/60 dark:text-dk-text/60 leading-snug">
                          {ed.location}
                        </p>
                        <p class="text-text/40 dark:text-dk-text/40 text-xs mt-1">
                          {ed.date}{ed.gpa ? ` · GPA ${ed.gpa}` : ""}
                        </p>
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
            <div id="experience">
              <p class="eyebrow text-acc-amber/90 mb-5">
                Experience
              </p>
              <ul class="space-y-5">
                {info.about.experience.map((ex) => {
                  const b = brandFor(ex.location);
                  return (
                    <li class="timeline-row text-sm">
                      <div
                        class="brand-badge"
                        style={`background: linear-gradient(135deg, ${b.from}, ${b.to});`}
                        aria-label={b.label}
                      >
                        <span>{b.acronym}</span>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="font-semibold text-text dark:text-dk-text leading-snug">
                          {ex.title}
                        </p>
                        <p class="text-text/60 dark:text-dk-text/60 leading-snug">
                          {ex.location}
                        </p>
                        <p class="text-text/40 dark:text-dk-text/40 text-xs mt-1">
                          {ex.date}
                        </p>
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>
        </div>

        <div id="skills" class="mt-14 lg:mt-16 pt-10 lg:pt-12 border-t border-text/10 dark:border-dk-text/10 reveal" data-reveal>
          <p class="eyebrow text-text/55 dark:text-dk-text/55 mb-2">Skills</p>
          <p class="text-sm text-text/55 dark:text-dk-text/55 mb-6 max-w-2xl">
            The toolkit, grouped the way I think about the work: four disciplines, AI engineering first.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {skillGroups.map((b) => (
              <div class="skills-card" style={`--sk: ${b.accent}; --sk-rgb: ${b.rgb};`}>
                <div class="skills-card-head">
                  <span class="skills-card-acronym" aria-hidden="true">{b.acronym}</span>
                  <p class="skills-card-label">{b.label}</p>
                </div>
                <div class="skill-tile-grid">
                  {b.items.map((it) => (
                    <span class="skill-tile">
                      <span class="skill-logo">
                        {it.file ? (
                          <img src={`/logos/skills/${it.file}.svg`} alt={it.name} loading="lazy" width="26" height="26" />
                        ) : (
                          <i class={it.icon} aria-hidden="true"></i>
                        )}
                      </span>
                      <span class="skill-tile-name">{it.name}</span>
                      <span class="skill-tip">{it.projects} project{it.projects > 1 ? "s" : ""}</span>
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Chapter 4: Writing ────────────────────────────────────────────── -->
    <section class="chapter snap-chapter chapter-fade" id="writing">
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="flex items-end justify-between mb-10 reveal" data-reveal>
          <div>
            <p class="eyebrow text-acc-emerald dark:text-acc-emerald mb-4" data-spine-dot>
              04 / Writing
            </p>
            <h2 class="display-sm text-text dark:text-dk-text glow-wave" data-spine-heading>
              Notes from <span class="text-acc-emerald">the work</span>.
            </h2>
            <p class="mt-4 text-base lg:text-lg text-text/65 dark:text-dk-text/70 leading-relaxed max-w-2xl">
              Stories from the systems I've built. Real numbers, real screwups, real fixes.
            </p>
          </div>
          <a
            href="/posts"
            class="link-underline text-sm font-semibold text-acc-emerald hidden lg:inline-flex"
          >
            All posts <span aria-hidden="true">→</span>
          </a>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 reveal"
          data-reveal
        >
          {latestPosts.map((post, i) => {
            const accents = ["blue", "emerald", "violet", "amber"];
            const accent = accents[i % accents.length];
            return (
              <a
                href={post.url}
                class={`no-lift post-card post-card-accent-${accent} group flex flex-col`}
              >
                {post.frontmatter.img_path && (
                  <div class="relative overflow-hidden">
                    <Image
                      src={post.frontmatter.img_path}
                      alt={post.frontmatter.img_alt || post.frontmatter.title}
                      width={600}
                      height={320}
                      class="w-full h-44 object-cover transition duration-500 group-hover:scale-[1.04]"
                    />
                    {i === 0 && (
                      <span class="absolute top-3 right-3 featured-badge text-[0.62rem]">
                        Latest
                      </span>
                    )}
                  </div>
                )}
                <div class="p-5 flex flex-col gap-3 flex-1">
                  <p class="text-[0.66rem] uppercase tracking-[0.18em] font-semibold text-text/40 dark:text-dk-text/40 tabular-nums">
                    {post.frontmatter.date}
                  </p>
                  <h3 class="text-lg lg:text-xl font-bold tracking-tight text-text dark:text-dk-text leading-[1.15] line-clamp-3 group-hover:text-secondary dark:group-hover:text-dk-secondary transition">
                    {post.frontmatter.title}
                  </h3>
                  <p class="text-[0.78rem] text-text/55 dark:text-dk-text/55 leading-relaxed line-clamp-2 mt-auto">
                    {post.frontmatter.description}
                  </p>
                </div>
              </a>
            );
          })}
        </div>

        <a
          href="/posts"
