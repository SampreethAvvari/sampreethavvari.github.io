---
import BaseLayout from "../layouts/BaseLayout.astro";
import TeachingBrowser from "../components/teaching/TeachingBrowser.tsx";
import { teaching } from "../data/teaching";
---

<BaseLayout title="SA: Teaching">
  <div class="teach-page">
    <header class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 pt-32 lg:pt-40">
      <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">
        Learn with me
      </p>
      <h1 class="display text-text dark:text-dk-text">Teaching.</h1>
      <p class="mt-5 max-w-2xl text-base lg:text-lg text-text/65 dark:text-dk-text/65 leading-relaxed">
        Handbooks, notes, and videos on building real engineering systems,
        grouped by discipline. Read them right here, and grab the PDF if it
        earns a spot on your shelf.
      </p>
    </header>

    <section class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 mt-12 lg:mt-16 mb-24">
      <TeachingBrowser client:load entries={teaching} />
    </section>
  </div>
</BaseLayout>

<style is:global>
  /* ── Filter chips (mirrors the gallery work-chip language) ──────────── */
  .teach-chip {
    --pa: #5b8def;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.42rem 0.95rem;
    border-radius: 9999px;
    font-size: 0.82rem;
    font-weight: 600;
    color: rgb(29 29 31 / 0.62);
    border: 1px solid rgb(29 29 31 / 0.12);
    background: transparent;
    transition: color 0.25s ease, border-color 0.25s ease, background 0.25s ease,
      box-shadow 0.25s ease;
    cursor: pointer;
  }
  html.dark .teach-chip {
    color: rgb(245 245 247 / 0.6);
    border-color: rgb(245 245 247 / 0.14);
  }
  .teach-chip:hover {
    color: #1d1d1f;
    border-color: color-mix(in srgb, var(--pa) 45%, rgb(29 29 31 / 0.12));
  }
  html.dark .teach-chip:hover { color: #f5f5f7; }
  .teach-chip-active {
    color: #1d1d1f;
    border-color: color-mix(in srgb, var(--pa) 60%, transparent);
    background: color-mix(in srgb, var(--pa) 12%, transparent);
    box-shadow: 0 0 18px -6px color-mix(in srgb, var(--pa) 55%, transparent);
  }
  html.dark .teach-chip-active {
    color: #f5f5f7;
    background: color-mix(in srgb, var(--pa) 18%, transparent);
  }
  .teach-chip-dim { opacity: 0.5; }

  /* ── Material card ──────────────────────────────────────────────────── */
  .teach-card {
    --pa: #5b8def;
    display: flex;
    flex-direction: column;
    border-radius: 1.1rem;
    overflow: hidden;
    background: rgb(255 255 255 / 0.5);
    border: 1px solid rgb(29 29 31 / 0.1);
    box-shadow: 0 10px 30px -22px rgb(0 0 0 / 0.4);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s ease,
      border-color 0.4s ease;
  }
  html.dark .teach-card {
    background: #0f1014;
    border-color: rgb(245 245 247 / 0.1);
  }
  .teach-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--pa) 55%, transparent);
    box-shadow: 0 24px 46px -24px rgb(0 0 0 / 0.5),
      0 0 34px -10px color-mix(in srgb, var(--pa) 40%, transparent);
  }
  .teach-card-cover {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #0b0c10;
  }
  .teach-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .teach-card:hover .teach-card-img { transform: scale(1.04); }
  .teach-badge {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.28rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #f5f5f7;
    background: rgb(5 6 8 / 0.66);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgb(255 255 255 / 0.14);
  }
  .teach-card-body { padding: 1rem 1.05rem 1.1rem; display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }
  .teach-card-stream {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--pa) 70%, #1d1d1f);
  }
  html.dark .teach-card-stream { color: color-mix(in srgb, var(--pa) 80%, #f5f5f7); }
  .teach-dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 9999px;
    background: var(--pa);
    box-shadow: 0 0 8px color-mix(in srgb, var(--pa) 65%, transparent);
  }
  .teach-card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: #1d1d1f;
  }
  html.dark .teach-card-title { color: #f5f5f7; }
  .teach-card:hover .teach-card-title { color: color-mix(in srgb, var(--pa) 55%, #1d1d1f); }
  html.dark .teach-card:hover .teach-card-title { color: color-mix(in srgb, var(--pa) 75%, #f5f5f7); }
  .teach-card-desc {
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgb(29 29 31 / 0.6);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  html.dark .teach-card-desc { color: rgb(245 245 247 / 0.6); }
  .teach-card-stats {
    margin-top: auto;
    padding-top: 0.7rem;
    display: flex;
    gap: 1rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: rgb(29 29 31 / 0.5);
    font-variant-numeric: tabular-nums;
  }
  html.dark .teach-card-stats { color: rgb(245 245 247 / 0.5); }
  .teach-card-stats i { opacity: 0.7; margin-right: 0.15rem; }

  /* ── Empty state ────────────────────────────────────────────────────── */
  .teach-empty {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.6rem 1.5rem;
    border-radius: 1rem;
    border: 1.5px dashed rgb(29 29 31 / 0.15);
  }
  html.dark .teach-empty { border-color: rgb(245 245 247 / 0.15); }
  .teach-empty-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 9999px;
    background: #34d399;
    box-shadow: 0 0 10px rgba(52, 211, 153, 0.6);
    flex: 0 0 auto;
  }
</style>
