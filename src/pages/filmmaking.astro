---
import BaseLayout from "../layouts/BaseLayout.astro";
import fs from "node:fs";
import path from "node:path";
import SmartImage from "../components/common/SmartImage.astro";

const title = "SA: Filmmaking";
const playlistUrl = "https://hi.switchy.io/q3Ng";
const screenplayUrl = "/among-monsters-screenplay.pdf";
const imdbUrl = "https://hi.switchy.io/q94P";
const photographyUrl = "https://hi.switchy.io/q3TE";

const posterSrc = "/among-monsters-poster.jpg";

const galleryDir = path.join(process.cwd(), "public", "Photo Gallery");
let galleryFiles = [];
try {
  galleryFiles = fs
    .readdirSync(galleryDir)
    .filter((file) => /\.(png|jpe?g|webp|gif|avif)$/i.test(file))
    .sort((a, b) => a.localeCompare(b));
} catch (error) {
  galleryFiles = [];
}

const galleryItems = galleryFiles.map((file) => {
  const encoded = encodeURIComponent(file);
  const src = `/Photo%20Gallery/${encoded}`;
  const alt = file.replace(/\.[^/.]+$/, "").replace(/[-_]+/g, " ");
  return { src, alt };
});

const swechchaDir = path.join(galleryDir, "Swechcha");
let swechchaFiles = [];
try {
  swechchaFiles = fs
    .readdirSync(swechchaDir)
    .filter((file) => /\.(png|jpe?g|webp|gif|avif)$/i.test(file))
    .sort((a, b) => a.localeCompare(b));
} catch (error) {
  swechchaFiles = [];
}

const swechchaItems = swechchaFiles.map((file) => {
  const encoded = encodeURIComponent(file);
  const src = `/Photo%20Gallery/Swechcha/${encoded}`;
  const alt = file.replace(/\.[^/.]+$/, "").replace(/[-_]+/g, " ");
  return { src, alt };
});

const crewPhoto = (filename) => ({
  src: `/Crew%20Photos/${encodeURIComponent(filename)}`,
  alt: filename.replace(/\.[^/.]+$/, ""),
});

const creativeRoleBg = (filename) => `/Creative%20Roles/${encodeURIComponent(filename)}`;

const instagramUrl = (handle) =>
  handle ? `https://instagram.com/${handle.replace(/^@/, "")}` : "";

const roles = [
  {
    title: "Director",
    items: ["Extraordinary Lives (upcoming)", "Among Monsters (2026)", "Tiger Man (2022)"],
    icon: "fas fa-clapperboard",
    background: creativeRoleBg("Director.jpg"),
    gridClass: "lg:col-start-1 lg:col-span-2",
  },
  {
    title: "Writer",
    items: [
      "Extraordinary Lives (upcoming)",
      "Pupa (upcoming)",
      "Among Monsters (2026)",
      "Tigerman (2022)",
    ],
    icon: "fas fa-pen-nib",
    background: creativeRoleBg("Write.jpg"),
    gridClass: "lg:col-start-3 lg:col-span-2",
  },
  {
    title: "Editor",
    items: ["Among Monsters (2026)", "Solistice (2025)", "Swecha (2024)", "Tigerman (2022)"],
    icon: "fas fa-scissors",
    background: creativeRoleBg("Editor.jpg"),
    gridClass: "lg:col-start-5 lg:col-span-2",
  },
  {
    title: "Cinematographer",
    items: ["Among Monsters (2026)", "Strangers (2019)"],
    icon: "fas fa-video",
    background: creativeRoleBg("Cinematographer.jpg"),
    gridClass: "lg:col-start-2 lg:col-span-2",
  },
  {
    title: "Music Composer",
    items: ["Among Monsters (2026)", "Strangers (2019)"],
    icon: "fas fa-music",
    background: creativeRoleBg("Music.jpg"),
    gridClass: "lg:col-start-4 lg:col-span-2",
  },
];

let galleryCursor = 0;
const pickGalleryImage = () => {
  if (!galleryItems.length) {
    return { src: "/paper.png", alt: "Placeholder image" };
  }
  const item = galleryItems[galleryCursor % galleryItems.length];
  galleryCursor += 1;
  return item;
};

const keyCreators = [
  {
    role: "Director / Writer",
    name: "Sampreeth Sharma",
    image: crewPhoto("Sampreeth.JPG"),
    instagram: "@sampreeth.sharma",
  },
  {
    role: "Director of Photography",
    name: "Isaac Chipe",
    image: crewPhoto("Isaac.jpg"),
    instagram: "@isaacchipedop",
  },
  {
    role: "Co-Writer",
    name: "Akash Munji",
    image: crewPhoto("Akash.jpg"),
    instagram: "@akumunji",
  },
];

const mainCast = [
  {
    name: "Sam Velletri",
    role: "John Reese / Harold Finch",
    image: crewPhoto("Sam Velletri.jpg"),
    instagram: "@samvelletri",
  },
  {
    name: "Matt Ehrmann",
    role: "",
    image: pickGalleryImage(),
    instagram: "@mattspaceship",
  },
  {
    name: "Kendall Hobson",
    role: "Carl",
    image: crewPhoto("Kendall.jpeg"),
    instagram: "@kenny.flair",
  },
  {
    name: "Lazaro Clapp",
    role: "",
    image: crewPhoto("Lazaro.png"),
    imageStyle: "object-position: 28% center;",
    instagram: "@lazaroclapp",
  },
  {
    name: "Alex Murray",
    role: "Sam",
    image: crewPhoto("Alex.jpeg"),
    instagram: "@cooldudemurray",
  },
  {
    name: "Evan Beskin",
    role: "Agent David",
    image: crewPhoto("Evan.png"),
    imageStyle: "object-position: 65% 60%; transform: scale(1.12);",
    instagram: "",
  },
];

const supportingCast = [
  {
    name: "Asli Mumtas",
    role: "Grace",
    image: crewPhoto("Asli.png"),
    imageStyle: "object-position: 70% center;",
    instagram: "@asliimumtas",
  },
  {
    name: "Tom Velletri",
    role: "Faith",
    image: crewPhoto("Tom Velletri.jpeg"),
    imageStyle: "object-position: 30% center; transform: scale(1.05);",
    instagram: "@tomvelletri",
  },
  {
    name: "Jordyn Andrea",
    role: "Sarah",
    image: crewPhoto("Jordyn.jpeg"),
    imageStyle: "transform: scale(1.05);",
    instagram: "@jordyn.andrea",
  },
  {
    name: "Luke Johnson",
    role: "Marcus",
    image: crewPhoto("Luke.jpeg"),
    instagram: "@lukeabjohnson",
  },
  {
    name: "Riyaan Jiwani",
    role: "Max",
    image: crewPhoto("Max.jpeg"),
    instagram: "@riyaan.jiwani",
  },
  {
    name: "Dylan Redford",
    role: "Unnamed FBI Agent",
    image: pickGalleryImage(),
    instagram: "@dylanredford",
  },
  {
    name: "Dhruv Sridhar",
    role: "Unnamed Drug Dealer",
    image: pickGalleryImage(),
    instagram: "@dhruv_sridhar",
  },
];

const musicCredits = [
  {
    name: "Sai Charan Thota",
    role: "PRO-JECT 53",
    image: pickGalleryImage(),
    instagram: "@charan_af",
  },
  {
    name: "Eknath Sravanam",
    role: "PRO-JECT 53",
    image: pickGalleryImage(),
    instagram: "@eknath_sravanam",
  },
];

// Festival-catalog filmography. Among Monsters uses the real poster; the
// others use tasteful gradient placeholder blocks (no new image files
// generated — gradient comes from a hashed colour pair below).
const filmography = [
  {
    title: "Among Monsters",
    year: "2026",
    roles: "Director, Writer, Editor, Music",
    poster: posterSrc,
    gradient: null,
  },
  {
    title: "Extraordinary Lives",
    year: "upcoming",
    roles: "Director, Writer",
    poster: null,
    gradient: "linear-gradient(155deg, #1a1d2e 0%, #2b2440 60%, #3a2a4f 100%)",
  },
  {
    title: "Pupa",
    year: "upcoming",
    roles: "Writer",
    poster: null,
    gradient: "linear-gradient(155deg, #1d2329 0%, #2a3a3a 55%, #3a4a3a 100%)",
  },
  {
    title: "Solistice",
    year: "2025",
    roles: "Editor",
    poster: null,
    gradient: "linear-gradient(155deg, #14181f 0%, #1f2a3a 55%, #2c3e57 100%)",
  },
  {
    title: "Swecha",
    year: "2024",
    roles: "Editor",
    poster: null,
    gradient: "linear-gradient(155deg, #1a1611 0%, #2e2317 55%, #4a341d 100%)",
  },
  {
    title: "Tiger Man",
    year: "2022",
    roles: "Director, Writer, Editor",
    poster: null,
    gradient: "linear-gradient(155deg, #1d1714 0%, #3a241b 55%, #5a2f1a 100%)",
  },
  {
    title: "Strangers",
    year: "2019",
    roles: "Cinematographer, Music",
    poster: null,
    gradient: "linear-gradient(155deg, #14141a 0%, #1f1d2a 55%, #2a253a 100%)",
  },
];

const stillsLimited = galleryItems.slice(0, 16);
---

<BaseLayout title={title} footerVariant="filmmaking">
  <div class="film-page">

    <!-- ── 1. Cinematic hero ──────────────────────────────────────────── -->
    <section class="film-hero relative overflow-hidden reveal" data-reveal>
      <div class="film-hero-backdrop" aria-hidden="true">
        <img src={posterSrc} alt="" class="film-hero-backdrop-img" />
        <div class="film-hero-backdrop-veil"></div>
      </div>

      <div class="relative z-10 mx-auto w-full max-w-screen-2xl px-6 lg:px-12 grid lg:grid-cols-12 items-center gap-10 lg:gap-16 py-24 lg:py-0">
        <div class="lg:col-span-5 flex justify-center lg:justify-start">
          <div class="film-poster-frame">
            <SmartImage
              src={posterSrc}
              alt="Among Monsters poster"
              class="film-poster-img"
              loading="eager"
            />
          </div>
        </div>

        <div class="lg:col-span-7 flex flex-col gap-6 text-center lg:text-left">
          <p class="eyebrow text-acc-amber">
            04 — Filmmaking
          </p>
          <h1 class="display text-white leading-[1.02]">
            Among Monsters.
          </h1>
          <p class="text-lg lg:text-2xl text-white/75 leading-relaxed max-w-2xl">
            An independent crime drama about gray characters, tight spaces, and the chaos hiding inside ordinary lives.
          </p>
          <p class="film-credit-line">
            Director · Writer · Editor · Music
          </p>
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 pt-2">
            <a
              href={imdbUrl}
              target="_blank"
              rel="noreferrer"
              class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 bg-white text-black text-sm font-semibold hover:opacity-85 transition"
            >
              <i class="fab fa-imdb text-base"></i>
              On IMDb <span aria-hidden="true">↗</span>
            </a>
            <a
              href={screenplayUrl}
              target="_blank"
              rel="noreferrer"
              class="no-lift inline-flex items-center gap-2 rounded-full px-6 py-3 border border-white/30 text-sm font-semibold text-white hover:bg-white/10 transition"
            >
              Read the screenplay
            </a>
          </div>
          <p class="text-sm text-white/60 tracking-wide">
            <span class="text-acc-amber">Premiering Nov 28</span> in Rochester · NYC soon
          </p>
        </div>
      </div>
    </section>

    <!-- ── 2. Filmography (horizontal scroll) ─────────────────────────── -->
    <section class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 mt-24 lg:mt-32 reveal" data-reveal>
      <div class="max-w-3xl mb-10 lg:mb-12">
        <p class="eyebrow text-acc-amber mb-3">
          Selected work
        </p>
        <h2 class="display-sm text-text dark:text-dk-text">
          Seven films, in order.
        </h2>
        <p class="mt-4 text-base lg:text-lg text-text/65 dark:text-dk-text/65 leading-relaxed">
          What I've directed, written, edited, shot, or scored. Some are out, some are in the cut, some are still pages.
        </p>
      </div>

      <div class="filmography-scroll">
        {filmography.map((film) => (
          <article class="film-card snap-start">
            <div class="film-card-poster">
              {film.poster ? (
                <SmartImage
                  src={film.poster}
                  alt={`${film.title} poster`}
                  class="film-card-poster-img"
                  loading="lazy"
                />
              ) : (
                <div
                  class="film-card-poster-placeholder"
                  style={`background-image: ${film.gradient};`}
                >
                  <div class="film-card-poster-noise"></div>
                  <div class="film-card-poster-meta">
                    <p class="film-card-poster-year">{film.year}</p>
                    <p class="film-card-poster-title">{film.title}</p>
                  </div>
                </div>
              )}
            </div>
            <div class="mt-4 flex items-baseline justify-between gap-3">
              <h3 class="text-base lg:text-lg font-semibold text-text dark:text-dk-text leading-tight">
                {film.title}
              </h3>
              <span class="font-mono text-xs tabular-nums text-acc-amber/85 shrink-0">
                {film.year}
              </span>
            </div>
            <p class="mt-1 text-[0.78rem] text-text/55 dark:text-dk-text/55 leading-snug">
              {film.roles}
            </p>
          </article>
        ))}
      </div>
      <p class="mt-4 text-xs text-text/40 dark:text-dk-text/40 lg:hidden">
        Swipe to scroll →
      </p>
    </section>

    <!-- ── 3. Creative roles (kept, polished) ─────────────────────────── -->
    <section class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 mt-24 lg:mt-32 reveal" data-reveal>
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-acc-amber mb-3">
          What I do on set
        </p>
        <h2 class="display-sm text-text dark:text-dk-text">
          Five hats. One sensibility.
        </h2>
      </div>

      <div class="grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 justify-items-center">
        {roles.map((role) => (
          <div
            class={`role-tile group ${role.gridClass}`}
            style={`background-image: url(${role.background});`}
          >
            <div class="role-tile-veil"></div>
            <div class="relative z-10 flex flex-col items-center text-center px-4">
              <i class={`${role.icon} text-3xl lg:text-4xl text-white mb-3 drop-shadow-lg`}></i>
              <h3 class="text-xl lg:text-2xl font-semibold text-white drop-shadow-lg">{role.title}</h3>
            </div>
            <div class="role-tile-hover">
              <ul class="text-sm lg:text-base text-text dark:text-dk-text space-y-1.5 font-medium text-center">
                {role.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 4. Among Monsters deep dive ────────────────────────────────── -->
    <section
      id="among-monsters"
      class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 mt-24 lg:mt-32 reveal"
      data-reveal
    >
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-acc-amber mb-3">
          The feature
        </p>
        <h2 class="display-sm text-text dark:text-dk-text">
          Among Monsters, in detail.
        </h2>
      </div>

      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">
        <div class="lg:col-span-5">
          <div class="lg:sticky lg:top-28">
            <div class="film-detail-poster">
              <SmartImage
                src={posterSrc}
                alt="Among Monsters poster"
                class="w-full h-auto rounded-2xl"
                loading="lazy"
              />
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 space-y-10">
          <div class="space-y-4">
            <p class="text-[0.7rem] uppercase tracking-[0.22em] text-text/40 dark:text-dk-text/40 font-semibold">
              Synopsis
            </p>
            <p class="text-base lg:text-lg text-text/80 dark:text-dk-text/80 leading-relaxed">
              A criminal trapped in a coward's body sets out to take revenge at any cost. Guns and drugs don't save people. The question isn't whether he breaks — it's how long he can keep going before the chaos finishes him.
            </p>
            <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed">
              I wrote, directed, edited, and scored it. We shot in Rochester across 2024 and 2025, in real living rooms and motel parking lots and the kind of streets the script kept asking for. The film premieres Nov 28 in Rochester, with an NYC screening to follow.
            </p>
          </div>

          <div class="space-y-4">
            <p class="text-[0.7rem] uppercase tracking-[0.22em] text-text/40 dark:text-dk-text/40 font-semibold">
              Core team
            </p>
            <ul class="divide-y divide-text/10 dark:divide-dk-text/10">
              {keyCreators.map((person) => (
                <li class="py-3 flex items-center justify-between gap-4">
                  <div class="min-w-0">
                    <p class="text-base font-semibold text-text dark:text-dk-text">{person.name}</p>
                    <p class="text-[0.72rem] uppercase tracking-[0.18em] text-text/50 dark:text-dk-text/55 mt-0.5">
                      {person.role}
                    </p>
                  </div>
                  {person.instagram && (
                    <a
                      href={instagramUrl(person.instagram)}
                      class="no-lift text-text/50 dark:text-dk-text/50 hover:text-acc-amber transition"
                      target="_blank"
                      rel="noreferrer"
                      aria-label={`${person.name} Instagram`}
                    >
                      <i class="fab fa-instagram text-lg"></i>
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

          <div class="flex flex-wrap items-center gap-3 pt-2">
            <a
              href={imdbUrl}
              target="_blank"
              rel="noreferrer"
              class="no-lift inline-flex items-center gap-2 rounded-full px-5 py-2.5 bg-text text-primary dark:bg-dk-text dark:text-dk-primary text-sm font-semibold hover:opacity-85 transition"
            >
              <i class="fab fa-imdb"></i> IMDb <span aria-hidden="true">↗</span>
            </a>
            <a
              href={screenplayUrl}
              target="_blank"
              rel="noreferrer"
              class="no-lift inline-flex items-center gap-2 rounded-full px-5 py-2.5 border border-text/20 dark:border-dk-text/25 text-sm font-semibold text-text dark:text-dk-text hover:bg-text/5 dark:hover:bg-dk-text/10 transition"
            >
              <i class="fas fa-file-lines"></i> Screenplay
            </a>
            <a
              href={playlistUrl}
              target="_blank"
              rel="noreferrer"
              class="no-lift inline-flex items-center gap-2 rounded-full px-5 py-2.5 border border-text/20 dark:border-dk-text/25 text-sm font-semibold text-text dark:text-dk-text hover:bg-text/5 dark:hover:bg-dk-text/10 transition"
            >
              <i class="fab fa-youtube"></i> Playlist
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 5. Crew & cast ─────────────────────────────────────────────── -->
    <section class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 mt-24 lg:mt-32 reveal" data-reveal>
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-acc-amber mb-3">
          Crew & cast
        </p>
        <h2 class="display-sm text-text dark:text-dk-text">
          The people who made the scene work.
        </h2>
      </div>

      <p class="text-[0.7rem] uppercase tracking-[0.22em] text-text/40 dark:text-dk-text/40 font-semibold mb-4">
        Above the line
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-12">
        {keyCreators.map((person) => (
          <article class="people-card group">
            <SmartImage
              src={person.image.src}
              alt={`${person.name} portrait`}
              class="people-card-img"
              loading="lazy"
            />
            <div class="people-card-veil"></div>
            <div class="people-card-meta">
              <p class="people-card-name">{person.name}</p>
              <div class="flex items-center justify-between gap-2">
                <p class="people-card-role">{person.role}</p>
                {person.instagram && (
                  <a
                    href={instagramUrl(person.instagram)}
                    class="no-lift text-white/75 hover:text-acc-amber transition shrink-0"
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`${person.name} Instagram`}
                  >
                    <i class="fab fa-instagram text-sm"></i>
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="text-[0.7rem] uppercase tracking-[0.22em] text-text/40 dark:text-dk-text/40 font-semibold mb-4">
        Cast
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-12">
        {[...mainCast, ...supportingCast].map((member) => (
          <article class="people-card group">
            <SmartImage
              src={member.image.src}
              alt={`${member.name} portrait`}
              class="people-card-img"
              style={member.imageStyle}
              loading="lazy"
            />
            <div class="people-card-veil"></div>
            <div class="people-card-meta">
              <p class="people-card-name">{member.name}</p>
              <div class="flex items-center justify-between gap-2">
                <p class="people-card-role">{member.role || "Cast"}</p>
                {member.instagram && (
                  <a
                    href={instagramUrl(member.instagram)}
                    class="no-lift text-white/75 hover:text-acc-amber transition shrink-0"
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`${member.name} Instagram`}
                  >
                    <i class="fab fa-instagram text-sm"></i>
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="text-[0.7rem] uppercase tracking-[0.22em] text-text/40 dark:text-dk-text/40 font-semibold mb-4">
        Music
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {musicCredits.map((member) => (
          <article class="people-card group">
            <SmartImage
              src={member.image.src}
              alt={`${member.name} portrait`}
              class="people-card-img"
              style={member.imageStyle}
              loading="lazy"
            />
            <div class="people-card-veil"></div>
            <div class="people-card-meta">
              <p class="people-card-name">{member.name}</p>
              <div class="flex items-center justify-between gap-2">
                <p class="people-card-role">{member.role}</p>
                {member.instagram && (
                  <a
                    href={instagramUrl(member.instagram)}
                    class="no-lift text-white/75 hover:text-acc-amber transition shrink-0"
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`${member.name} Instagram`}
                  >
                    <i class="fab fa-instagram text-sm"></i>
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ── 6. Stills gallery ──────────────────────────────────────────── -->
    <section class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 mt-24 lg:mt-32 reveal" data-reveal>
      <div class="max-w-3xl mb-10">
        <p class="eyebrow text-acc-amber mb-3">
          Stills
        </p>
        <h2 class="display-sm text-text dark:text-dk-text">
          On set.
        </h2>
      </div>

      {stillsLimited.length ? (
