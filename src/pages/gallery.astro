import BaseLayout from "../layouts/BaseLayout.astro";
import fs from "node:fs";
import path from "node:path";

const title = "SA: Gallery";

/*
  Filesystem-driven gallery.

  Drop screenshots (png / jpg / jpeg / webp / gif / avif) and documents (pdf)
  into  public/gallery/<project-slug>/  and they appear here on the next build.
  - File order: alphabetical with numeric awareness Гўв‚¬вЂќ prefix "01-", "02-" to control order.
  - Captions: derived from the filename ("03-analyze-tab dark.png" ГўвЂ вЂ™ "analyze tab dark").
  - New project: create a new folder under public/gallery/. It shows up automatically
    with a title derived from the folder name. Add it to PROJECTS below whenever
    you want a custom title, blurb, or accent.
*/

const ACCENTS = ["#22D3EE", "#34D399", "#5B8DEF", "#A78BFA", "#F5A524", "#FB7185"];

const PROJECTS = [
  {
    slug: "doc-coach",
    title: "Doc Coach",
    blurb:
      "Every implant consultation, graded on the CEO's seven-criterion rubric and delivered as a color-coded coaching report.",
    accent: "#22D3EE",
  },
  {
    slug: "treatment-estimator",
    title: "Treatment Estimator",
    blurb:
      "The quoting platform treatment coordinators use mid-consult, with price locks the database itself enforces.",
    accent: "#34D399",
  },
  {
    slug: "cowork-dashboard",
    title: "Cowork Dashboard",
    blurb: "Two clinics, six tabs, one set of numbers everyone finally trusts.",
    accent: "#5B8DEF",
  },
  {
    slug: "npc-coach",
    title: "NPC Coach",
    blurb:
      "Agentic grading for every intake call, with coaching that reaches coordinators automatically.",
    accent: "#A78BFA",
  },
  {
    slug: "ai-hour",
    title: "AI Hour",
    blurb:
      "The weekly hands-on lab where the whole corporate team learns what AI can actually do.",
    accent: "#F5A524",
  },
  {
    slug: "cbct-scan-validator",
    title: "CBCT Scan Validator",
    blurb:
      "The quality gate that catches bad dental CT scans before they ever reach the design queue.",
    accent: "#FB7185",
  },
];

const workRoot = path.join(process.cwd(), "public", "gallery");
const IMG_RE = /\.(png|jpe?g|webp|gif|avif)$/i;
const PDF_RE = /\.pdf$/i;

const listDir = (slug: string): string[] => {
  try {
    return fs.readdirSync(path.join(workRoot, slug));
  } catch {
    return [];
  }
};

const humanSize = (bytes: number): string => {
  if (bytes >= 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  if (bytes >= 1024) return `${Math.round(bytes / 1024)} KB`;
  return `${bytes} B`;
};

const captionFor = (file: string): string =>
  file
    .replace(/\.[^/.]+$/, "")
    .replace(/^\d+[-_. ]+/, "")
    .replace(/[-_]+/g, " ")
    .trim();

const titleFromSlug = (slug: string): string =>
  slug.replace(/[-_]+/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());

// Folders on disk that aren't configured above still get a section.
let discovered: string[] = [];
try {
  discovered = fs
    .readdirSync(workRoot, { withFileTypes: true })
    .filter((d) => d.isDirectory())
    .map((d) => d.name);
} catch {
  discovered = [];
}
const known = new Set(PROJECTS.map((p) => p.slug));
const extras = discovered
  .filter((slug) => !known.has(slug))
  .sort()
  .map((slug, i) => ({
    slug,
    title: titleFromSlug(slug),
    blurb: "",
    accent: ACCENTS[(PROJECTS.length + i) % ACCENTS.length],
  }));

const sections = [...PROJECTS, ...extras].map((cfg, idx) => {
  const files = listDir(cfg.slug).sort((a, b) =>
    a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" })
  );
  const images = files
    .filter((f) => IMG_RE.test(f))
    .map((f) => ({
      src: `/gallery/${encodeURIComponent(cfg.slug)}/${encodeURIComponent(f)}`,
      caption: captionFor(f),
    }));
  const docs = files
    .filter((f) => PDF_RE.test(f))
    .map((f) => {
      let size = "";
      try {
        size = humanSize(fs.statSync(path.join(workRoot, cfg.slug, f)).size);
      } catch {
        size = "";
      }
      return {
        href: `/gallery/${encodeURIComponent(cfg.slug)}/${encodeURIComponent(f)}`,
        name: captionFor(f),
        size,
      };
    });
  return {
    ...cfg,
    number: String(idx + 1).padStart(2, "0"),
    images,
    docs,
    count: images.length + docs.length,
  };
});

const totalImages = sections.reduce((n, s) => n + s.images.length, 0);
const totalDocs = sections.reduce((n, s) => n + s.docs.length, 0);
const liveSections = sections.filter((s) => s.count > 0).length;
---

<BaseLayout title={title}>
  <div class="work-gallery-page">
    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Hero ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <header class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 pt-32 lg:pt-40 reveal" data-reveal>
      <p class="eyebrow text-secondary dark:text-dk-secondary mb-4">
        The work Г‚В· up close
      </p>
      <h1 class="display text-text dark:text-dk-text">Proof of work.</h1>
      <p class="mt-5 max-w-2xl text-base lg:text-lg text-text/65 dark:text-dk-text/65 leading-relaxed">
        Screenshots and documents straight from the systems I build and run in
        production, organized by project. Everything here is live software that
        real people at a real company use every week.
      </p>
      <p class="mt-4 font-mono text-xs tracking-wide text-text/45 dark:text-dk-text/45 tabular-nums">
        {totalImages} screenshots Г‚В· {totalDocs} documents Г‚В· {liveSections}/{sections.length} projects live
      </p>
    </header>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Sticky project rail ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <nav
      class="work-rail sticky top-14 lg:top-16 z-40 mt-10 bg-primary/80 dark:bg-dk-primary/75 backdrop-blur-xl backdrop-saturate-150 border-y border-text/5 dark:border-dk-text/10"
      aria-label="Projects on this page"
    >
      <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
        <div class="work-rail-track flex items-center gap-2 overflow-x-auto py-3">
          {sections.map((s) => (
            <a
              href={`#p-${s.slug}`}
              class="work-chip no-lift"
              data-chip={s.slug}
              style={`--pa: ${s.accent};`}
            >
              <span class="work-chip-dot" aria-hidden="true"></span>
              <span>{s.title}</span>
              {s.count > 0 && (
                <span class="work-chip-count tabular-nums">{s.count}</span>
              )}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Project sections ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    {sections.map((s) => (
      <section
        id={`p-${s.slug}`}
        data-spy={s.slug}
        class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12 mt-20 lg:mt-28 scroll-mt-36 lg:scroll-mt-40"
        style={`--pa: ${s.accent};`}
      >
        <div class="max-w-3xl reveal" data-reveal>
          <p class="eyebrow mb-3" style={`color: ${s.accent};`}>
            {s.number} / {s.title}
          </p>
          <h2 class="display-sm text-text dark:text-dk-text">{s.title}.</h2>
          {s.blurb && (
            <p class="mt-3 text-base lg:text-lg text-text/65 dark:text-dk-text/65 leading-relaxed">
              {s.blurb}
            </p>
          )}
          {s.count > 0 && (
            <p class="mt-3 font-mono text-[0.7rem] tracking-wide text-text/40 dark:text-dk-text/40 tabular-nums">
              {s.images.length} screenshots{s.docs.length ? ` Г‚В· ${s.docs.length} documents` : ""}
            </p>
          )}
        </div>

        {s.count === 0 ? (
          <div class="work-empty mt-8">
            <span class="work-empty-dot" aria-hidden="true"></span>
            <p class="text-sm font-medium text-text/55 dark:text-dk-text/55">
              Curating screenshots for this one Гўв‚¬вЂќ soon.
            </p>
          </div>
        ) : (
          <>
            {s.images.length > 0 && (
              <div class="work-masonry mt-10">
                {s.images.map((img, i) => (
                  <figure class="shot">
                    <button
                      type="button"
                      class="shot-frame no-lift"
                      data-shot
                      data-group={s.slug}
                      data-index={i}
                      data-full={img.src}
                      data-caption={img.caption}
                      aria-label={`View screenshot: ${img.caption}`}
                    >
                      <span class="shot-bar" aria-hidden="true">
                        <span class="shot-dots">
                          <span></span><span></span><span></span>
                        </span>
                        <span class="shot-title">{img.caption}</span>
                        <span class="shot-expand">
                          <i class="fas fa-up-right-and-down-left-from-center"></i>
                        </span>
                      </span>
                      <img
                        src={img.src}
                        alt={img.caption || `${s.title} screenshot`}
                        loading="lazy"
                        decoding="async"
                        class="shot-img"
                      />
                    </button>
                  </figure>
                ))}
              </div>
            )}

            {s.docs.length > 0 && (
              <div class="mt-10 reveal" data-reveal>
                <p class="text-[0.7rem] uppercase tracking-[0.22em] text-text/40 dark:text-dk-text/40 font-semibold mb-4">
                  Documents
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  {s.docs.map((doc) => (
                    <a
                      href={doc.href}
                      target="_blank"
                      rel="noreferrer"
                      class="work-doc no-lift group"
                    >
                      <span class="work-doc-icon" aria-hidden="true">
                        <i class="fas fa-file-pdf"></i>
                      </span>
                      <span class="min-w-0 flex-1">
                        <span class="block text-sm font-semibold text-text dark:text-dk-text leading-snug truncate capitalize">
                          {doc.name}
                        </span>
                        <span class="block mt-0.5 font-mono text-[0.68rem] text-text/45 dark:text-dk-text/45 tabular-nums">
                          PDF{doc.size ? ` Г‚В· ${doc.size}` : ""}
                        </span>
                      </span>
                      <span class="work-doc-open" aria-hidden="true">ГўвЂ вЂ”</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </>
        )}
      </section>
    ))}

    <div class="h-24 lg:h-32"></div>

    <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Lightbox ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
    <div id="wlb" class="wlb" hidden role="dialog" aria-modal="true" aria-label="Screenshot viewer">
      <div class="wlb-backdrop" data-wlb-close></div>
      <button type="button" class="wlb-btn wlb-close no-lift" data-wlb-close aria-label="Close viewer">
        <i class="fas fa-xmark"></i>
      </button>
      <button type="button" class="wlb-btn wlb-prev no-lift" data-wlb-prev aria-label="Previous screenshot">
        <i class="fas fa-chevron-left"></i>
      </button>
      <figure class="wlb-stage">
        <img id="wlb-img" alt="" />
        <figcaption class="wlb-caption">
          <span id="wlb-cap" class="capitalize"></span>
          <span id="wlb-count" class="font-mono tabular-nums"></span>
        </figcaption>
      </figure>
      <button type="button" class="wlb-btn wlb-next no-lift" data-wlb-next aria-label="Next screenshot">
        <i class="fas fa-chevron-right"></i>
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  // ГўвЂќв‚¬ГўвЂќв‚¬ Lightbox ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  const wlb = document.getElementById("wlb");
  const wlbImg = document.getElementById("wlb-img") as HTMLImageElement | null;
  const wlbCap = document.getElementById("wlb-cap");
  const wlbCount = document.getElementById("wlb-count");

  type Item = { src: string; caption: string };
  let items: Item[] = [];
  let cursor = 0;

  const collect = (group: string): Item[] =>
    Array.from(
      document.querySelectorAll<HTMLElement>(`[data-shot][data-group="${group}"]`)
    ).map((el) => ({
      src: el.dataset.full || "",
      caption: el.dataset.caption || "",
    }));

  const preload = (i: number) => {
    const it = items[i];
    if (it) new Image().src = it.src;
  };

  const render = () => {
    if (!wlbImg || !wlbCap || !wlbCount) return;
    const it = items[cursor];
    if (!it) return;
    wlbImg.classList.remove("wlb-img-in");
    wlbImg.onload = () => wlbImg.classList.add("wlb-img-in");
    wlbImg.src = it.src;
    wlbImg.alt = it.caption;
    wlbCap.textContent = it.caption;
    wlbCount.textContent = `${cursor + 1} / ${items.length}`;
    preload(cursor + 1);
    preload(cursor - 1);
  };

  const open = (group: string, index: number) => {
    if (!wlb) return;
    items = collect(group);
    cursor = Math.min(Math.max(index, 0), items.length - 1);
    wlb.hidden = false;
    requestAnimationFrame(() => wlb.classList.add("wlb-open"));
    document.documentElement.classList.add("wlb-lock");
    render();
  };

  const close = () => {
    if (!wlb) return;
    wlb.classList.remove("wlb-open");
    document.documentElement.classList.remove("wlb-lock");
    window.setTimeout(() => {
      wlb.hidden = true;
    }, 220);
  };

  const step = (delta: number) => {
    if (!items.length) return;
    cursor = (cursor + delta + items.length) % items.length;
    render();
  };

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const shot = target.closest<HTMLElement>("[data-shot]");
    if (shot) {
      open(shot.dataset.group || "", Number(shot.dataset.index || 0));
      return;
    }
    if (target.closest("[data-wlb-close]")) close();
    if (target.closest("[data-wlb-prev]")) step(-1);
    if (target.closest("[data-wlb-next]")) step(1);
  });

  document.addEventListener("keydown", (e) => {
    if (!wlb || wlb.hidden) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") step(-1);
    if (e.key === "ArrowRight") step(1);
  });

  // Swipe navigation on touch devices.
  let touchX: number | null = null;
  wlb?.addEventListener(
    "touchstart",
    (e) => {
      touchX = e.touches[0]?.clientX ?? null;
    },
    { passive: true }
  );
  wlb?.addEventListener(
    "touchend",
    (e) => {
      if (touchX === null) return;
      const dx = (e.changedTouches[0]?.clientX ?? touchX) - touchX;
      if (Math.abs(dx) > 48) step(dx < 0 ? 1 : -1);
      touchX = null;
    },
    { passive: true }
  );

  // ГўвЂќв‚¬ГўвЂќв‚¬ Scrollspy for the project rail ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
  const chips = new Map<string, HTMLElement>();
  document
    .querySelectorAll<HTMLElement>("[data-chip]")
    .forEach((chip) => chips.set(chip.dataset.chip || "", chip));

  const setActive = (slug: string) => {
    chips.forEach((chip, key) => {
      const on = key === slug;
      chip.classList.toggle("work-chip-active", on);
      if (on) {
        // Scroll only the horizontal rail, never the page: scrollIntoView
        // walks every scrollable ancestor and yanks the document's vertical
        // scroll back toward the sticky rail while the user is scrolling.
        const track = chip.closest<HTMLElement>(".work-rail-track");
        if (track) {
          const left = chip.offsetLeft - (track.clientWidth - chip.offsetWidth) / 2;
          track.scrollTo({ left: Math.max(0, left), behavior: "smooth" });
        }
      }
    });
  };

  if ("IntersectionObserver" in window) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActive((entry.target as HTMLElement).dataset.spy || "");
          }
        });
      },
      { rootMargin: "-25% 0px -65% 0px" }
    );
    document.querySelectorAll<HTMLElement>("[data-spy]").forEach((el) => spy.observe(el));
  }
</script>

