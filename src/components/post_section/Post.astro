---
import { Image } from "astro:assets";

const { post, index = 0 } = Astro.props;
const { url } = post;
const { title, description, img_path, img_alt, date, tag, tone } =
  post.frontmatter;

const ACCENTS = ["blue", "emerald", "violet", "amber", "cyan"];
const TAG_TONE = {
  MLOps: "emerald",
  Architecture: "blue",
  Engineering: "blue",
  Process: "amber",
  Research: "violet",
  Personal: "cyan",
  Filmmaking: "amber",
};
const accent = ACCENTS[index % ACCENTS.length];
const chipTone = tone || TAG_TONE[tag] || "blue";
const displayTag = tag || "Engineering";
---

<a
  href={url}
  class={`no-lift post-card post-card-accent-${accent} group`}
>
  {
    img_path && (
      <div class="relative overflow-hidden">
        <Image
          src={img_path}
          alt={img_alt || title}
          width={600}
          height={320}
          class="w-full h-48 object-cover transition duration-500 group-hover:scale-[1.04]"
        />
        <span class={`absolute top-3 left-3 post-tag post-tag-${chipTone}`}>
          {displayTag}
        </span>
      </div>
    )
  }
  <div class="p-5 flex flex-col gap-2.5 flex-1">
    <p
      class="text-[0.68rem] uppercase tracking-[0.16em] font-semibold text-text/45 dark:text-dk-text/45 tabular-nums"
    >
      {date}
    </p>
    <h3
      class="text-[1rem] font-semibold text-text dark:text-dk-text leading-snug line-clamp-3 group-hover:text-secondary dark:group-hover:text-dk-secondary transition min-h-[3.4rem]"
    >
      {title}
    </h3>
    <p
      class="text-xs text-text/60 dark:text-dk-text/65 leading-relaxed line-clamp-3 mt-auto"
    >
      {description}
    </p>
    <p
      class="text-xs font-semibold text-secondary dark:text-dk-secondary inline-flex items-center gap-1.5 mt-1"
    >
      Read more <span aria-hidden="true">→</span>
    </p>
  </div>
</a>
