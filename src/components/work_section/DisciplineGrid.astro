---
// Landing-page "01 / What I do" section: the four disciplines as side-by-side
// accent-washed panels. Each panel previews two projects + one article and
// links into its /work/<slug> deep dive. Data: src/data/disciplines.ts.
import { disciplines } from "../../data/disciplines";
import { Image } from "astro:assets";

const statusTone = (s: string) =>
  s === "In production" || s === "Live" || s === "Running program"
    ? "dx-chip-live"
    : s === "Pilot-ready" || s === "In build"
      ? "dx-chip-soon"
      : "dx-chip-design";
---

<section class="chapter snap-chapter chapter-fade" id="disciplines">
  <div class="mx-auto w-full max-w-screen-2xl px-6 lg:px-12">
    <div class="max-w-4xl reveal" data-reveal>
      <p class="eyebrow text-secondary dark:text-dk-secondary mb-3" data-spine-dot>
        01 / What I do
      </p>
      <h2 class="display-sm text-text dark:text-dk-text mb-3 glow-wave" data-spine-heading>
        Four disciplines, one engineer.
      </h2>
      <p class="text-base lg:text-lg text-text/70 dark:text-dk-text/70 leading-relaxed max-w-2xl">
        Most of this work comes from Hybridge, a dental implant company where
        I've been the only engineer in the building. It splits into four kinds
        of engineering, and every shipped system borrows from all of them.
      </p>
    </div>

    {/* Flagship — JobPilot. The one project that spans all four disciplines, so
        it carries all four accent colours (top hairline + AIE·FDE·MLE·SDE row).
        Sits above the four discipline cards as the lead-in to them. */}
    <div
      class="mt-8 lg:mt-10 reveal rounded-2xl border border-text/12 dark:border-dk-text/15 overflow-hidden"
      data-reveal
      style="background: linear-gradient(135deg, rgba(91,141,239,0.05), rgba(167,139,250,0.03) 55%, transparent 80%);"
    >
      <div class="h-[3px] w-full" style="background: linear-gradient(90deg,#34D399 0%,#F5A524 34%,#A78BFA 67%,#5B8DEF 100%);"></div>
      <div class="grid lg:grid-cols-[minmax(0,42%)_1fr]">
        <a
          href="/posts/jobpilot-v2"
          class="no-lift group block relative overflow-hidden max-lg:aspect-[16/9] lg:min-h-full"
          aria-label="Read the JobPilot story"
        >
          <Image
            src="/jobpilot-flagship.png"
            alt="JobPilot: four colored data streams converging into one tailored resume taking flight"
            width={900}
            height={506}
            class="w-full h-full object-cover transition duration-500 group-hover:scale-[1.03]"
          />
          <span class="absolute top-3 left-3 featured-badge text-[0.62rem]">Flagship</span>
        </a>
        <div class="p-6 lg:p-8 flex flex-col justify-center">
          <div class="flex items-center gap-2 font-mono text-[0.7rem] font-bold tracking-[0.16em]">
            <span style="color:#34D399;">AIE</span>
            <span class="text-text/25 dark:text-dk-text/25">·</span>
            <span style="color:#F5A524;">FDE</span>
            <span class="text-text/25 dark:text-dk-text/25">·</span>
            <span style="color:#A78BFA;">MLE</span>
            <span class="text-text/25 dark:text-dk-text/25">·</span>
            <span style="color:#5B8DEF;">SDE</span>
            <span class="ml-1.5 font-sans tracking-normal text-[0.72rem] text-text/45 dark:text-dk-text/45">one system, all four</span>
          </div>
          <a href="/posts/jobpilot-v2" class="no-lift group">
            <h3 class="mt-3 text-2xl lg:text-3xl font-bold tracking-tight text-text dark:text-dk-text group-hover:text-secondary dark:group-hover:text-dk-secondary transition">
              JobPilot <span aria-hidden="true">✈</span>
            </h3>
          </a>
          <p class="mt-2 text-sm lg:text-base text-text/70 dark:text-dk-text/70 leading-relaxed max-w-2xl">
            My open-source job-hunt autopilot. It watches 160+ company boards, scores
            every role against my profile, and writes a tailored resume and cover
            letter per match. The one portfolio piece I run on myself.
          </p>
          <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2">
            <span class="text-sm"><span class="font-semibold tabular-nums text-text dark:text-dk-text">160+</span> <span class="text-text/50 dark:text-dk-text/50">boards</span></span>
            <span class="text-sm"><span class="font-semibold text-text dark:text-dk-text">AI copilot</span> <span class="text-text/50 dark:text-dk-text/50">per-job chat</span></span>
            <span class="text-sm"><span class="font-semibold tabular-nums text-text dark:text-dk-text">&lt;$10/mo</span> <span class="text-text/50 dark:text-dk-text/50">end to end</span></span>
          </div>
          <div class="mt-5 flex flex-wrap items-center gap-3">
            <a
              href="/posts/jobpilot-v2"
              class="no-lift inline-flex items-center gap-1.5 rounded-full px-5 py-2.5 bg-text text-primary dark:bg-dk-text dark:text-dk-primary text-sm font-semibold hover:opacity-85 transition"
            >
              Read the story <span aria-hidden="true">→</span>
            </a>
            <a
              href="https://hi.switchy.io/yIOl"
              target="_blank"
              rel="noreferrer"
              class="no-lift inline-flex items-center gap-1.5 rounded-full px-5 py-2.5 border border-text/20 dark:border-dk-text/20 text-sm font-semibold text-text dark:text-dk-text hover:bg-text/5 dark:hover:bg-dk-text/10 transition"
            >
              GitHub <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div
      class="mt-8 lg:mt-12 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 lg:gap-5 reveal"
      data-reveal
    >
      {disciplines.map((d, i) => (
        <a
          href={`/work/${d.slug}`}
          class={`no-lift dx-panel group dx-delay-${i}`}
          style={`--dx: ${d.accent}; --dx-rgb: ${d.rgb};`}
        >
          <div class="dx-panel-head">
            <span class="dx-acronym">{d.acronym}</span>
            <span class="dx-icon" aria-hidden="true"><i class={d.icon}></i></span>
          </div>
          <h3 class="dx-name">{d.name}</h3>
          <p class="dx-tagline">{d.tagline}</p>

          <ul class="dx-previews">
            {d.projects.slice(0, 2).map((p) => (
              <li class="dx-preview-row">
                {p.img && (
                  <Image
                    src={p.img}
                    alt=""
                    width={96}
                    height={64}
                    class="dx-thumb"
                  />
                )}
                <div class="min-w-0">
                  <p class="dx-preview-name">{p.name}</p>
                  <span class={`dx-chip ${statusTone(p.status)}`}>{p.status}</span>
                </div>
              </li>
            ))}
            {d.articles.slice(0, 1).map((a) => (
              <li class="dx-preview-row dx-preview-article">
                {a.img && (
                  <Image src={a.img} alt="" width={96} height={64} class="dx-thumb" />
                )}
                <div class="min-w-0">
                  <p class="dx-preview-kicker">From the blog</p>
                  <p class="dx-preview-name">{a.title}</p>
                </div>
              </li>
            ))}
          </ul>

          <span class="dx-explore">
            Explore {d.acronym}
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </a>
      ))}
    </div>

    <div class="mt-8 flex items-center justify-between flex-wrap gap-4">
      <a
        href="/work"
        class="link-underline text-sm font-semibold text-secondary dark:text-dk-secondary"
      >
        The full work breakdown <span aria-hidden="true">→</span>
      </a>
      <p class="text-xs text-text/40 dark:text-dk-text/40">
        AIE and FDE are where I live; MLE and SDE are how it ships
      </p>
    </div>
  </div>
</section>
