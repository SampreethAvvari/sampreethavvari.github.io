---
// Scroll spine — the fairy-comet that falls down the left side of the home
// page as you scroll. No visible path: the comet's trajectory is computed
// procedurally — a little orbit (twirl) around an axis that hugs the left
// content margin (the eyebrow-dot column) and descends with scroll progress,
// so it corkscrews downward like a fairy falling, twirling. While you rest,
// it keeps spinning slowly in place and shedding glitter. Head + smudged
// glitter tail are painted on a canvas with the same particle language as
// the cursor trail in Pointer.jsx, just softer and longer-lived. It
// recolours per chapter, igniting eyebrow dots ([data-spine-dot]) and
// flaring section headings ([data-spine-heading]) as it passes their
// height. Desktop only, honours prefers-reduced-motion.
---

<div class="scroll-spine" aria-hidden="true" data-scroll-spine>
  <canvas class="spine-canvas" data-spine-canvas></canvas>
</div>

<script>
  // Colour the comet takes on inside each chapter (matches eyebrow accents).
  const ACCENTS: Record<string, string> = {
    work: "#5B8DEF",
    about: "#5B8DEF",
    writing: "#34D399",
    filmmaking: "#F5A524",
    contact: "#5B8DEF",
  };

  // The fairy twirl: an ellipse orbit around a descending axis.
  const SPIRAL = {
    rx: 22, // horizontal twirl radius
    ry: 12, // vertical twirl radius
    wavelength: 520, // px of descent per full twirl
    idleSpin: (Math.PI * 2) / 14000, // rad/ms — slow pirouette at rest
  };

  // Smudge/glitter tuning — same family as the cursor trail in Pointer.jsx,
  // but bigger specks, wider halos, fainter and slower so the tail reads as
  // a soft smudge rather than bright sparks.
  const P = {
    radius: [0.7, 2.3] as [number, number],
    life: [56, 104] as [number, number], // frames
    friction: 0.94,
    haloRatio: 9,
    fade: 0.52, // alpha = t^fade — lower = lingers longer = smudgier
    emitSpacing: 6, // px of comet travel per speck
    maxEmitPerFrame: 36,
    jitter: 6, // px of scatter around the twirl
    idleEvery: 10, // frames between idle twinkles
  };

  const root = document.querySelector<HTMLElement>("[data-scroll-spine]");
  const wrapper = root?.closest<HTMLElement>(".snap-chapters");

  if (root && wrapper) {
    const canvas = root.querySelector<HTMLCanvasElement>("[data-spine-canvas]")!;
    const ctx = canvas.getContext("2d")!;

    const desktop = window.matchMedia("(min-width: 1024px)");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    type Anchor = { el: HTMLElement; y: number; color: string };
    let anchors: Anchor[] = [];
    let headings: Anchor[] = [];
    let axisX = 32; // twirl axis x — middle of the left gutter, set in build()
    let wrapTop = 0;
    let wrapH = 1;
    let built = false;

    // Twirl state carried between frames so the smudge traces the corkscrew.
    let prevBaseY: number | null = null;
    let prevTheta = 0;
    let head: { x: number; y: number } | null = null;

    const rand = (min: number, max: number) => Math.random() * (max - min) + min;
    const clamp = (v: number, lo: number, hi: number) =>
      Math.min(hi, Math.max(lo, v));

    // ── Colour helpers ──────────────────────────────────────────────
    const rgbOf = (hex: string): [number, number, number] => {
      const n = parseInt(hex.slice(1), 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    const mixToWhite = (c: [number, number, number], t: number) =>
      c.map((v) => Math.round(v + (255 - v) * t)) as [number, number, number];

    let accentHex = "#5B8DEF";
    let accentRgb = rgbOf(accentHex);
    let palette: [number, number, number][] = [];
    const setAccent = (hex: string) => {
      if (hex === accentHex && palette.length) return;
      accentHex = hex;
      accentRgb = rgbOf(hex);
      // accent twice so it dominates, a lightened accent, a near-white spark
      palette = [accentRgb, accentRgb, mixToWhite(accentRgb, 0.5), [244, 244, 247]];
    };
    setAccent(accentHex);

    // ── Particles (world coordinates, drawn in viewport space) ─────
    type Speck = {
      x: number; y: number; vx: number; vy: number;
      r: number; c: [number, number, number];
      life: number; maxLife: number;
    };
    let specks: Speck[] = [];

    const emit = (x: number, y: number, vx: number, vy: number) => {
      specks.push({
        x, y, vx, vy,
        r: rand(P.radius[0], P.radius[1]),
        c: palette[Math.floor(Math.random() * palette.length)],
        life: rand(P.life[0], P.life[1]),
        maxLife: 0,
      });
      specks[specks.length - 1].maxLife = specks[specks.length - 1].life;
    };

    let dpr = 1;
    const sizeCanvas = () => {
      dpr = window.devicePixelRatio || 1;
      canvas.width = Math.floor(window.innerWidth * dpr);
      canvas.height = Math.floor(window.innerHeight * dpr);
      canvas.style.width = `${window.innerWidth}px`;
      canvas.style.height = `${window.innerHeight}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    // Transform-free coordinates relative to the wrapper, so the in-flight
    // reveal animations (translateY) don't skew where we think dots live.
    const offsetTo = (el: HTMLElement) => {
      let x = 0;
      let y = 0;
      let n: HTMLElement | null = el;
      while (n && n !== wrapper) {
        x += n.offsetLeft;
        y += n.offsetTop;
        n = n.offsetParent as HTMLElement | null;
      }
      return { x, y };
    };

    const build = () => {
      if (!desktop.matches) {
        built = false;
        return;
      }
      const dots = Array.from(
        document.querySelectorAll<HTMLElement>("[data-spine-dot]"),
      );
      if (dots.length < 2) return;

      wrapTop = wrapper.getBoundingClientRect().top + window.scrollY;
      wrapH = wrapper.offsetHeight;
      sizeCanvas();

      const xs: number[] = [];
      anchors = dots.map((el) => {
        const o = offsetTo(el);
        const section = el.closest("section");
        xs.push(o.x + 3.2);
        return {
          el,
          y: o.y + el.offsetHeight / 2,
          color: ACCENTS[section?.id ?? ""] || "#5B8DEF",
        };
      });
      // Park the twirl axis in the unused left gutter: halfway between the
      // viewport edge and the dot column on narrow desktops, drifting closer
      // to (but clear of) the content on very wide screens. Centered
      // eyebrows (Connect) would pull the column to mid-page, so it takes
      // the leftmost dot.
      const colX = Math.min(...xs);
      axisX = Math.max(colX * 0.5, colX - 90);

      // Section headings flare when the comet passes them.
      headings = Array.from(
        document.querySelectorAll<HTMLElement>("[data-spine-heading]"),
      ).map((el) => {
        const o = offsetTo(el);
        const section = el.closest("section");
        const color = ACCENTS[section?.id ?? ""] || "#5B8DEF";
        const [r, g, b] = rgbOf(color);
        el.style.setProperty("--head-rgb", `${r}, ${g}, ${b}`);
        return { el, y: o.y + el.offsetHeight / 2, color };
      });

      built = true;
      prevBaseY = null; // re-anchor the smudge after a relayout
      head = null;
      update();
    };

    // The orbit axis descends with pure scroll progress: top of page = top
    // edge, full scroll = bottom of the wrapper — never above or below the
    // fold, since the axis also sweeps down the viewport as progress grows.
    const currentBaseY = () => {
      const maxScroll = Math.max(
        1,
        document.documentElement.scrollHeight - window.innerHeight,
      );
      const t = clamp(window.scrollY / maxScroll, 0, 1);
      return clamp(
        window.scrollY - wrapTop + window.innerHeight * t,
        4,
        wrapH - 6,
      );
    };

    // Dot ignition + heading flares + comet colour, driven by axis height.
    const update = () => {
      if (!built || !desktop.matches) return;
      if (reduceMotion.matches) {
        anchors.forEach((a) => a.el.classList.add("dot-lit"));
        return;
      }
      const baseY = currentBaseY();
      let color = "#5B8DEF";
      for (const a of anchors) {
        const passed = baseY >= a.y - 6;
        a.el.classList.toggle("dot-lit", passed);
        if (passed) color = a.color;
      }
      for (const hd of headings) {
        hd.el.classList.toggle("heading-lit", baseY >= hd.y - 10);
      }
      setAccent(color);
    };

    // ── Render loop: twirl the comet, shed glitter, draw ────────────
    let frameCount = 0;
    const render = () => {
      requestAnimationFrame(render);
      if (!built || !desktop.matches || reduceMotion.matches) return;
      frameCount++;

      const w = window.innerWidth;
      const h = window.innerHeight;
      ctx.clearRect(0, 0, w, h);
      const viewY = window.scrollY - wrapTop;

      // Fairy position: orbit around the descending axis. Scroll advances
      // the twirl phase; time keeps a slow pirouette going at rest.
      const baseY = currentBaseY();
      const theta =
        (baseY / SPIRAL.wavelength) * Math.PI * 2 +
        performance.now() * SPIRAL.idleSpin;
      const hx = axisX + SPIRAL.rx * Math.cos(theta);
      const hy = baseY + SPIRAL.ry * Math.sin(theta);

      // Shed glitter along the actual corkscrew between frames.
      if (prevBaseY !== null) {
        const dTheta = theta - prevTheta;
        const travel =
          Math.abs(baseY - prevBaseY) + Math.abs(dTheta) * SPIRAL.rx;
        if (travel > 1.5) {
          const steps = Math.min(
            P.maxEmitPerFrame,
            Math.max(1, Math.floor(travel / P.emitSpacing)),
          );
          for (let i = 0; i < steps; i++) {
            const f = (i + Math.random()) / steps;
            const bY = prevBaseY + (baseY - prevBaseY) * f;
            const th = prevTheta + dTheta * f;
            emit(
              axisX + SPIRAL.rx * Math.cos(th) + rand(-P.jitter, P.jitter),
              bY + SPIRAL.ry * Math.sin(th) + rand(-P.jitter, P.jitter),
              rand(-0.3, 0.3),
              rand(-0.3, 0.3),
            );
          }
        }
      }
      prevBaseY = baseY;
      prevTheta = theta;
      head = { x: hx, y: hy };

      ctx.globalCompositeOperation = "lighter";

      // Idle twinkle so the fairy glitters even between scrolls.
      if (frameCount % P.idleEvery === 0) {
        emit(
          hx + rand(-7, 7),
          hy + rand(-7, 7),
          rand(-0.35, 0.35),
          rand(-0.35, 0.35),
        );
      }

      // Specks — soft radial halos twinkling out, smudgier than the cursor's.
      for (let i = specks.length - 1; i >= 0; i--) {
        const p = specks[i];
        p.vx *= P.friction;
        p.vy *= P.friction;
        p.x += p.vx;
        p.y += p.vy;
        p.life -= 1;
        if (p.life <= 0) {
          specks.splice(i, 1);
          continue;
        }
        const sy = p.y - viewY;
        if (sy < -80 || sy > h + 80) continue;
        const alpha = Math.pow(p.life / p.maxLife, P.fade);
        const haloR = p.r * P.haloRatio;
        const [r, g, b] = p.c;
        const grd = ctx.createRadialGradient(p.x, sy, 0, p.x, sy, haloR);
        grd.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${0.55 * alpha})`);
        grd.addColorStop(0.35, `rgba(${r}, ${g}, ${b}, ${0.2 * alpha})`);
        grd.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
        ctx.beginPath();
        ctx.fillStyle = grd;
        ctx.arc(p.x, sy, haloR, 0, Math.PI * 2);
        ctx.fill();
      }

      // Comet head — a soft breathing bloom with a hot white core.
      const hvy = hy - viewY;
      if (hvy > -60 && hvy < h + 60) {
        const pulse = 1 + 0.12 * Math.sin(performance.now() / 380);
        const [r, g, b] = accentRgb;
        const bloomR = 34 * pulse;
        const bloom = ctx.createRadialGradient(hx, hvy, 0, hx, hvy, bloomR);
        bloom.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0.32)`);
        bloom.addColorStop(0.4, `rgba(${r}, ${g}, ${b}, 0.13)`);
        bloom.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
        ctx.beginPath();
        ctx.fillStyle = bloom;
        ctx.arc(hx, hvy, bloomR, 0, Math.PI * 2);
        ctx.fill();

        const core = ctx.createRadialGradient(hx, hvy, 0, hx, hvy, 7);
        core.addColorStop(0, "rgba(255, 255, 255, 0.65)");
        core.addColorStop(0.45, `rgba(${r}, ${g}, ${b}, 0.32)`);
        core.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
        ctx.beginPath();
        ctx.fillStyle = core;
        ctx.arc(hx, hvy, 7, 0, Math.PI * 2);
        ctx.fill();
      }

      ctx.globalCompositeOperation = "source-over";
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };

    let resizeTimer: ReturnType<typeof setTimeout>;
    const onResize = () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(build, 200);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
    window.addEventListener("load", build);
    desktop.addEventListener("change", build);
    reduceMotion.addEventListener("change", build);
    build();
    requestAnimationFrame(render);
  }
</script>
