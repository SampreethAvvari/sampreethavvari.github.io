  | "arrow-right"
  | "arrow-up-right"
  | "search"
  | "clock"
  | "mail"
  | "github"
  | "linkedin"
  | "instagram"
  | "imdb"
  | "film";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

