---
import { Image } from "astro:assets";
import { optimizedSources } from "../../utils/optimizedImage";

type Props = {
  src: string | ImageMetadata;
  alt: string;
  class?: string;
  style?: string;
  width?: number;
  height?: number;
  loading?: "eager" | "lazy";
  decoding?: "async" | "sync" | "auto";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
};

const {
  src,
  alt,
  class: className,
  style,
  width,
  height,
  loading = "lazy",
  decoding = "async",
  fetchpriority,
  sizes,
} = Astro.props as Props;

const isImported = typeof src === "object";
// For /public string paths, serve AVIF/WebP siblings when they exist on disk
// (generated by scripts/optimize-images*.mjs). Existence-guarded so we never
// emit a <source> that 404s.
const opt = !isImported ? optimizedSources(src as string) : null;
---

{
  isImported ? (
    <Image
      src={src as ImageMetadata}
      alt={alt}
      class={className}
      style={style}
      width={width}
      height={height}
      sizes={sizes}
    />
  ) : opt ? (
    <picture>
      <source srcset={opt.avif} type="image/avif" />
      <source srcset={opt.webp} type="image/webp" />
      <img
        src={opt.webp}
        alt={alt}
        class={className}
        style={style}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    </picture>
  ) : (
    <img
      src={src as string}
      alt={alt}
      class={className}
      style={style}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
    />
  )
}
