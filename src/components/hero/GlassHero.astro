---
// Raymarched glass metaballs, hand-written WebGL (no dependencies). Three
// blobs melt into each other; one follows the cursor. Fresnel rim light in
// the four discipline colours, refraction of a flowing gradient, specular.
// The canvas only runs on desktop fine-pointer devices with motion allowed;
// everyone else gets the static aurora field. The rAF loop pauses whenever
// the canvas is offscreen or the tab is hidden.
import Picture from "../common/Picture.astro";
---

<div class="glass-hero" aria-hidden="true">
  <canvas class="glass-hero-canvas" data-glasshero></canvas>
  <div class="glass-hero-fallback">
    <Picture class="glass-hero-img glass-hero-img-dark" src="/hero-aurora-dark.png" alt="" loading="eager" />
    <Picture class="glass-hero-img glass-hero-img-light" src="/hero-aurora-light.png" alt="" loading="eager" />
  </div>
</div>

<style>
  .glass-hero,
  .glass-hero-fallback {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .glass-hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: none;
  }
  /* html gets .glasshero-on from the script only when WebGL actually runs. */
  :global(html.glasshero-on) .glass-hero-canvas { display: block; }
  :global(html.glasshero-on) .glass-hero-fallback { display: none; }
  .glass-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }
  .glass-hero-img-dark { display: none; }
  :global(html.dark) .glass-hero-img-dark { display: block; }
  :global(html.dark) .glass-hero-img-light { display: none; }
</style>

<script>
  (function () {
    const canvas = document.querySelector<HTMLCanvasElement>("[data-glasshero]");
    if (!canvas) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = window.matchMedia("(pointer: fine)").matches;
    const wide = window.matchMedia("(min-width: 1024px)").matches;
    if (reduce || !fine || !wide) return;

    const gl = canvas.getContext("webgl", {
      alpha: true,
      antialias: false,
      premultipliedAlpha: false,
    });
    if (!gl) return;

    const VS = "attribute vec2 aP; void main(){ gl_Position = vec4(aP, 0., 1.); }";
    const FS = `
precision highp float;
uniform vec2 uRes; uniform float uT; uniform vec2 uM; uniform float uDark;
uniform vec2 uCk; uniform float uCkT;
float smin(float a,float b,float k){ float h=clamp(.5+.5*(b-a)/k,0.,1.); return mix(b,a,h)-k*h*(1.-h); }
/* Click shockwave: a radial pressure wave from the click point. Nearby blobs
   get shoved outward and wobble back as the wave decays. */
vec2 shove(vec2 c){
  if(uCkT>3.) return vec2(0.);
  vec2 rel=c-uCk;
  float d=length(rel)+1e-4;
  float a=exp(-2.1*uCkT)*exp(-d*1.05)*sin(9.5*uCkT-d*7.)*.3;
  return (rel/d)*a;
}
float map(vec3 p){
  float t=uT*.5;
  vec2 b1=vec2(sin(t)*.55, cos(t*.8)*.4);   b1+=shove(b1);
  vec2 b2=vec2(cos(t*.7)*.7, sin(t*.55)*.55); b2+=shove(b2);
  vec2 b3=uM*1.25;                            b3+=shove(b3);
  float d=length(p-vec3(b1, sin(t*.6)*.15))-.62;
  d=smin(d, length(p-vec3(b2, cos(t*.4)*.2))-.42, .5);
  d=smin(d, length(p-vec3(b3, .1))-.34, .55);
  return d;
}
vec3 nrm(vec3 p){ vec2 e=vec2(.0015,0.);
  return normalize(vec3(map(p+e.xyy)-map(p-e.xyy), map(p+e.yxy)-map(p-e.yxy), map(p+e.yyx)-map(p-e.yyx))); }
vec3 bgcol(vec2 uv){
  float t=uT*.12;
  vec3 c=mix(vec3(.204,.827,.6), vec3(.655,.545,.98), .5+.5*sin(uv.x*1.8+t));
  c=mix(c, vec3(.961,.647,.141), (.5+.5*sin(uv.y*2.-t*1.4))*.5);
  c=mix(c, vec3(.357,.553,.937), (.5+.5*sin((uv.x+uv.y)*1.4+t*.8))*.55);
  return c;
}
void main(){
  vec2 uv=(gl_FragCoord.xy*2.-uRes)/min(uRes.x,uRes.y);
  vec3 ro=vec3(0.,0.,2.3), rd=normalize(vec3(uv,-1.55));
  float td=0., d=1.; vec3 p=ro;
  for(int i=0;i<44;i++){ p=ro+rd*td; d=map(p); if(d<.0025||td>4.5) break; td+=d*.95; }
  vec4 col=vec4(0.);
  if(d<.0025){
    vec3 n=nrm(p);
    float fres=pow(1.-max(dot(n,-rd),0.), 2.4);
    vec3 through=bgcol(uv+n.xy*.42)*(uDark>.5? .5 : .78);
    vec3 rim=bgcol(n.xy*1.6)*fres*1.7;
    float spec=pow(max(dot(reflect(rd,n), normalize(vec3(.55,.7,.45))),0.), 42.);
    vec3 c=through*.62+rim+vec3(spec);
    float a=clamp(.3+fres*.9, 0., .96);
    col=vec4(c, a*(uDark>.5? .9 : .72));
  }
  /* Expanding refraction ripple from the click: a thin glass ring with
     chromatic dispersion (each channel rides a slightly different radius),
     tinted by the flowing gradient it "refracts". */
  if(uCkT<2.4){
    float dd=length(uv-uCk);
    float rr=.12+uCkT*1.15;
    float fade=exp(-uCkT*2.1);
    float bR=exp(-pow((dd-rr*.985)*15.,2.));
    float bG=exp(-pow((dd-rr)*15.,2.));
    float bB=exp(-pow((dd-rr*1.02)*15.,2.));
    vec3 tint=bgcol(uv+vec2(bG*.25));
    vec3 ring=vec3(bR,bG,bB)*(.55+tint*.8);
    col.rgb+=ring*fade;
    col.a=max(col.a, max(bR,max(bG,bB))*fade*(uDark>.5? .6 : .45));
  }
  gl_FragColor=col;
}`;

    function compile(type: number, src: string) {
      const s = gl.createShader(type);
      if (!s) return null;
      gl.shaderSource(s, src);
      gl.compileShader(s);
      if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) return null;
      return s;
    }
    const vs = compile(gl.VERTEX_SHADER, VS);
    const fs = compile(gl.FRAGMENT_SHADER, FS);
    if (!vs || !fs) return;
    const pr = gl.createProgram();
    if (!pr) return;
    gl.attachShader(pr, vs);
    gl.attachShader(pr, fs);
    gl.linkProgram(pr);
    if (!gl.getProgramParameter(pr, gl.LINK_STATUS)) return;
    gl.useProgram(pr);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
    const loc = gl.getAttribLocation(pr, "aP");
    gl.enableVertexAttribArray(loc);
    gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
    const uRes = gl.getUniformLocation(pr, "uRes");
    const uT = gl.getUniformLocation(pr, "uT");
    const uM = gl.getUniformLocation(pr, "uM");
    const uDark = gl.getUniformLocation(pr, "uDark");
    const uCk = gl.getUniformLocation(pr, "uCk");
    const uCkT = gl.getUniformLocation(pr, "uCkT");
    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

    // WebGL is alive: switch from fallback image to canvas.
    document.documentElement.classList.add("glasshero-on");

    let mx = 0.6, my = 0.1, tmx = 0.6, tmy = 0.1;
    let visible = true, hidden = false;
    let ckX = 0, ckY = 0, ckAt = -1e9;

    const sceneCoords = (clientX: number, clientY: number) => {
      const r = canvas.getBoundingClientRect();
      if (r.height === 0) return null;
      const minSide = Math.min(r.width, r.height);
      return {
        x: (((clientX - r.left) / r.width) * 2 - 1) * (r.width / minSide),
        y: -(((clientY - r.top) / r.height) * 2 - 1) * (r.height / minSide),
      };
    };

    window.addEventListener(
      "mousemove",
      (e) => {
        const c = sceneCoords(e.clientX, e.clientY);
        if (!c) return;
        tmx = c.x;
        tmy = c.y;
      },
      { passive: true },
    );

    // Clicking anywhere in the hero fires a shockwave from the click point:
    // the blobs get shoved and wobble back, and a chromatic refraction
    // ripple expands outward.
    const heroSection = canvas.closest("section");
    (heroSection || canvas).addEventListener(
      "pointerdown",
      (e) => {
        const c = sceneCoords(e.clientX, e.clientY);
        if (!c) return;
        ckX = c.x;
        ckY = c.y;
        ckAt = performance.now();
      },
      { passive: true },
    );

    function size() {
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5) * 0.8;
      canvas.width = Math.max(1, Math.floor(canvas.clientWidth * dpr));
      canvas.height = Math.max(1, Math.floor(canvas.clientHeight * dpr));
      gl.viewport(0, 0, canvas.width, canvas.height);
    }
    size();
    window.addEventListener("resize", size, { passive: true });

    new IntersectionObserver((en) => { visible = en[0].isIntersecting; }, { threshold: 0 }).observe(canvas);
    document.addEventListener("visibilitychange", () => { hidden = document.hidden; });

    const isDark = () => document.documentElement.classList.contains("dark");
    const t0 = performance.now();
    (function frame() {
      requestAnimationFrame(frame);
      if (!visible || hidden) return;
      mx += (tmx - mx) * 0.06;
      my += (tmy - my) * 0.06;
      gl.uniform2f(uRes, canvas.width, canvas.height);
      gl.uniform1f(uT, (performance.now() - t0) / 1000);
      gl.uniform2f(uM, mx, my);
      gl.uniform1f(uDark, isDark() ? 1 : 0);
      gl.uniform2f(uCk, ckX, ckY);
      gl.uniform1f(uCkT, (performance.now() - ckAt) / 1000);
      gl.clearColor(0, 0, 0, 0);
      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.drawArrays(gl.TRIANGLES, 0, 3);
    })();
  })();
</script>
