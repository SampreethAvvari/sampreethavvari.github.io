---
// "Connect with me" block shown at the end of every teaching material.
import Picture from "../common/Picture.astro";
import { info } from "../../data/info";
const { email, linkedin, github } = info.contact;
---

<section class="mx-auto w-full max-w-3xl px-6 lg:px-0 mt-16 mb-4">
  <div class="teach-brand">
    <div class="teach-brand-id">
      <div class="teach-brand-ava">
        <Picture
          src={info.picture}
          alt={info.picture_alt}
          width={120}
          height={120}
          loading="lazy"
        />
      </div>
      <div class="min-w-0">
        <p class="teach-brand-eyebrow">Made by</p>
        <p class="teach-brand-name">{info.name}</p>
        <p class="teach-brand-role">{info.role} · {info.location}</p>
      </div>
    </div>

    <p class="teach-brand-note">
      If this helped, the best thanks is telling me what to write next. Or just
      say hi.
    </p>

    <div class="teach-brand-links">
      <a class="teach-brand-btn teach-brand-btn-primary no-lift" href={linkedin} target="_blank" rel="noreferrer">
        <i class="fab fa-linkedin"></i><span>Connect on LinkedIn</span>
      </a>
      <a class="teach-brand-btn no-lift" href={`mailto:${email}`}>
        <i class="fas fa-envelope"></i><span>{email}</span>
      </a>
      <a class="teach-brand-btn no-lift" href={github} target="_blank" rel="noreferrer" aria-label="GitHub">
        <i class="fab fa-github"></i><span>GitHub</span>
      </a>
    </div>
  </div>
</section>

<style>
  .teach-brand {
    position: relative;
    border-radius: 1.25rem;
    padding: 1.6rem 1.5rem;
    background:
      radial-gradient(120% 140% at 0% 0%, rgba(52, 211, 153, 0.1), transparent 55%),
      rgba(29, 29, 31, 0.02);
    border: 1px solid rgb(29 29 31 / 0.1);
    overflow: hidden;
  }
  :global(html.dark) .teach-brand {
    background:
      radial-gradient(120% 140% at 0% 0%, rgba(52, 211, 153, 0.16), transparent 55%),
      rgba(245, 245, 247, 0.03);
    border-color: rgb(245 245 247 / 0.12);
  }
  .teach-brand-id {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .teach-brand-ava {
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 9999px;
    overflow: hidden;
    flex: 0 0 auto;
    box-shadow: 0 0 0 1px rgb(255 255 255 / 0.12), 0 0 22px -8px rgba(52, 211, 153, 0.7);
  }
  .teach-brand-ava :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .teach-brand-eyebrow {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-weight: 600;
    color: rgb(29 29 31 / 0.4);
  }
  :global(html.dark) .teach-brand-eyebrow { color: rgb(245 245 247 / 0.4); }
  .teach-brand-name {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #1d1d1f;
    line-height: 1.15;
  }
  :global(html.dark) .teach-brand-name { color: #f5f5f7; }
  .teach-brand-role {
    font-size: 0.8rem;
    color: rgb(29 29 31 / 0.55);
  }
  :global(html.dark) .teach-brand-role { color: rgb(245 245 247 / 0.55); }
  .teach-brand-note {
    margin: 1rem 0 1.1rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgb(29 29 31 / 0.7);
    max-width: 46ch;
  }
  :global(html.dark) .teach-brand-note { color: rgb(245 245 247 / 0.7); }
  .teach-brand-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .teach-brand-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem;
    border-radius: 9999px;
    font-size: 0.82rem;
    font-weight: 600;
    border: 1px solid rgb(29 29 31 / 0.12);
    color: rgb(29 29 31 / 0.78);
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  :global(html.dark) .teach-brand-btn { color: rgb(245 245 247 / 0.8); border-color: rgb(245 245 247 / 0.14); }
  .teach-brand-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(52, 211, 153, 0.5);
    color: #1d1d1f;
  }
  :global(html.dark) .teach-brand-btn:hover { color: #f5f5f7; }
  .teach-brand-btn-primary {
    background: linear-gradient(135deg, #34d399, #10b981);
    color: #04150f;
    border-color: transparent;
  }
  :global(html.dark) .teach-brand-btn-primary { color: #04150f; }
  .teach-brand-btn-primary:hover { color: #04150f; opacity: 0.94; }
</style>
